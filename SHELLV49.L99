  CC5A   04C4           	CLR	R4	 		;FORCE FIRST DISK READ
  CC5C   C804 CDD8      	MOV	R4,@MCNT	
                        ;
                        ;---PARSE	PROCEDURE	PARAMETERS
                        ;
  CC60   04E0 CD6C      	CLR	@VSW	 		;CLEAR VIEW SWITCH
  CC64   04E0 CD6E      	CLR	@NSW	 		;CLEAR NO-EXECUTE SWITHC
