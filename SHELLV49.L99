  CCC4   0281 2000      	CI	R1,2000H 		;SPACE OR CTL CHAR?
  CCC8   1B04           	JH	PARS2	 		;NO
  CCCA   C000           	MOV	R0,R0	 		;YES,WORD SWITCH CLEAR?
  CCCC   13D8           	JEQ	PARSLOOP	 		;YES,CONTINUE
  CCCE   04C0           	CLR	R0	 		;NO,CLEAR IT AND CONTINUE
  CCD0   10D6           	JMP	PARSLOOP	
