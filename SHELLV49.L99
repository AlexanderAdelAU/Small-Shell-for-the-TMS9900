  CC82   0281 2D00      	CI	R1,2D00H 		;CMD LINE SWITCH(-)?
  CC86   161A           	JNE	PARS1	 		;NO
  CC88   C000           	MOV	R0,R0	 		;BEGINNING OF WORD?
  CC8A   1616           	JNE	PARS0B	 		;NO,CONTINUE
  CC8C   0584           	INC	R4	
