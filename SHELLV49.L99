  CC78   0202 000A      	LI	R2,10	 		;MAX PARMS ALLOWED 
  CC7C   04C0           	CLR	R0	 		;R0 = WORD SWITCH(ZERO BETWEEN WORDS)
  CC7E   04C1           PARSLOOP	CLR	R1	
