                        ;*******************************************************************
                        ;	MAP_INIT - clear all 16 map registers to page 0
                        ;	Entry: none  Exit: R0=0, R1=0, R12=MAP_WIN_BASE+32
                        ;	Called at shell cold start and LOADERCODE entry.
                        ;*******************************************************************
  E03C   04CF           MAP_INIT:	CLR	R15
  E03E   008F           	LST	R15
  E040   020C 80C0      	LI	R12,MAP_WIN_BASE
  E044   04C0           	CLR	R0
  E046   0201 0010      	LI	R1,NUM_MAP_ENTRIES
  E04A   3080           MAPI_L:	LDCR	R0,BYTEWIDE
  E04C   05CC           	INCT	R12
  E04E   0601           	DEC	R1
  E050   16FC           	JNE	MAPI_L
  E052   045B           	RT
                        
                        ;*******************************************************************
                        ;	MAP_SET - program one 6116 map register
                        ;	Entry: R9=segment (0-15), R0=page (0-3)
                        ;	Exit:  R9 clobbered (segment*2), R0 clobbered, R12=CRU addr
                        ;	Note:  R8 is safe - use R8 to preserve values across MAP_SET
                        ;*******************************************************************
                        MAP_SET:
  E054   020C 80C0      	LI	R12,MAP_WIN_BASE
  E058   0A19           	SLA	R9,1			;SEGMENT * 2 = CRU BIT OFFSET
  E05A   A309           	A	R9,R12
  E05C   0A80           	SLA	R0,8			;MOVE PAGE TO HIGH BYTE (LDCR BYTE TRANSFER USES HIGH BYTE)
  E05E   3080           	LDCR	R0,BYTEWIDE
  E060   045B           	RT
                        
  E062                  PPTRS	BSS	22
  E078                  PBUF	BSS	64
  E0B8   0000           PPADDR	WORD	0
                        
  E0BA                  	END

