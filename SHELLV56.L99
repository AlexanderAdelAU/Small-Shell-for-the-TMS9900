  DFD6   0380           INT_SAFE:	RTWP
                        
                        ;	INT2_HANDLER - Paged execution crash debug
                        ;
                        ;	Fires when an exception occurs in paged code.
                        ;	Prints PC, WP, ST at point of exception, then dumps
                        ;	all 16 map registers, then returns to monitor.
                        ;*******************************************************************
                        INT2_HANDLER:
  DFD8   2FA0 E01C      	MESG	@TXT_INT2PC
  DFDC   2E8E           	WHEX	R14			;PC AT EXCEPTION
  DFDE   2FA0 E026      	MESG	@TXT_INT2WP
  DFE2   2E8D           	WHEX	R13			;WORKSPACE POINTER
  DFE4   2FA0 E02C      	MESG	@TXT_INT2ST
  DFE8   2E8F           	WHEX	R15			;STATUS REGISTER
  DFEA   2FA0 E038      	MESG	@TXT_INT2NL
  DFEE   04C9           	CLR	R9
  DFF0   2C89           	PSEL	R9			;DISABLE PSEL BEFORE READING MAP REGISTERS
  DFF2   2FA0 E032      	MESG	@TXT_INT2MAP
  DFF6   020C 80C0      	LI	R12,MAP_WIN_BASE
  DFFA   04C8           	CLR	R8
                        INT2_ML:
  DFFC   04C1           	CLR	R1
  DFFE   3481           	STCR	R1,BYTEWIDE
  E000   09E1           	SRL	R1,14
  E002   2E81           	WHEX	R1
  E004   0200 2000      	LI	R0,2000H
  E008   2F00           	WRITE	R0
  E00A   05CC           	INCT	R12
  E00C   0588           	INC	R8
  E00E   0288 0010      	CI	R8,16
  E012   1AF4           	JL	INT2_ML
  E014   2FA0 E038      	MESG	@TXT_INT2NL
  E018   0460 F004      	B	@0F004H
                        
