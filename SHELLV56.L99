                        ;*******************************************************************
                        ;	TYPE
                        ;*******************************************************************
                        ;*******************************************************************
                        ;	LOAD - load overlay into paged memory without executing
                        ;
                        ;	Usage: LOAD filename
                        ;	Loads the COM file, programs mapper registers per pagemap,
                        ;	copies code to paged memory, returns to shell without executing.
                        ;*******************************************************************
                        DOLOAD:
                        	;--- SKIP 'LOAD', PARSE OVERLAY FILENAME ---
  D9BA   0203 0250      	LI	R3,CMDLINE
  D9BE   9833 D015      DLSK1	CB	*R3+,@SPACE		;SKIP COMMAND NAME
  D9C2   1BFD           	JH	DLSK1
  D9C4   0603           	DEC	R3
  D9C6   9813 D018      DLSK2	CB	*R3,@CR			;END OF LINE?
  D9CA   1602           	JNE	DLSK_E
  D9CC   0460 DADC      	B	@DLERR
  D9D0   9833 D015      DLSK_E	CB	*R3+,@SPACE		;SKIP SPACES
  D9D4   12F8           	JLE	DLSK2
  D9D6   0603           	DEC	R3
  D9D8   2DA0 D1C2      	CALL	@PARSENAME		;FCB = OVERLAY NAME+EXT
                        
                        	;--- OPEN FILE ---
  D9DC   0204 0280      	LI	R4,FCB
  D9E0   04E4 001A      	CLR	@CRN(R4)
  D9E4   0202 000F      	LI	R2,FOPEN
  D9E8   0203 0280      	LI	R3,FCB
  D9EC   2DA0 E400      	CALL	@BDOS
  D9F0   C041           	MOV	R1,R1
  D9F2   1402           	JHE	DLSK_F
  D9F4   0460 DADC      	B	@DLERR
                        DLSK_F
                        
                        	;--- READ FIRST SECTOR ---
  D9F8   0203 0500      	LI	R3,STAGING
  D9FC   0202 001A      	LI	R2,SETDMA
  DA00   2DA0 E400      	CALL	@BDOS
  DA04   0202 0014      	LI	R2,RDSEQ
  DA08   0203 0280      	LI	R3,FCB
  DA0C   2DA0 E400      	CALL	@BDOS
  DA10   0281 FFFF      	CI	R1,-1
  DA14   1602           	JNE	DLSK_G
  DA16   0460 DADC      	B	@DLERR
                        DLSK_G
                        
                        	;--- PROCESS CHAIN BLOCKS ---
                        	; Header: next_offset(w) page(w) start(w) size(w) [data]
  DA1A   0206 0500      	LI	R6,STAGING			; CURRENT POINTER
  DA1E   0208 0700      	LI	R8,STAGING_END			; END OF STAGING
                        
                        DLBLK:
  DA22   C1C6           	MOV	R6,R7				; R7 = HEADER START
  DA24   C176           	MOV	*R6+,R5				; R5 = NEXT_OFFSET
  DA26   C136           	MOV	*R6+,R4				; R4 = PAGE
  DA28   C0B6           	MOV	*R6+,R2				; R2 = START (DESTINATION)
  DA2A   C0F6           	MOV	*R6+,R3				; R3 = SIZE IN BYTES
                        
                        	;--- MAP_SET IF PAGED ---
  DA2C   C004           	MOV	R4,R0
  DA2E   1304           	JEQ	DLCPY_S				; PAGE 0 = NO MAP_SET
  DA30   C242           	MOV	R2,R9
  DA32   09C9           	SRL	R9,12				; SEGMENT = START>>12
  DA34   06A0 E054      	BL	@MAP_SET			; R9=SEGMENT R0=PAGE
                        
                        DLCPY_S:
  DA38   0209 0100      	LI	R9,PSEL_EN
  DA3C   2C89           	PSEL	R9				; PSEL ON
  DA3E   0913           	SRL	R3,1				; BYTES TO WORDS
                        DLCPY:
  DA40   CCB6           	MOV	*R6+,*R2+			; COPY WORD
  DA42   0603           	DEC	R3
  DA44   1327           	JEQ	DLDONE_B			; BLOCK DONE
  DA46   8206           	C	R6,R8
  DA48   1AFB           	JL	DLCPY
                        
                        	;--- STAGING EXHAUSTED - RELOAD ---
  DA4A   04C9           	CLR	R9
  DA4C   2C89           	PSEL	R9				; PSEL OFF
  DA4E   064A           	DECT	SP
  DA50   C687           	MOV	R7,*SP				; SAVE HEADER START
  DA52   064A           	DECT	SP
  DA54   C685           	MOV	R5,*SP				; SAVE NEXT_OFFSET
  DA56   064A           	DECT	SP
  DA58   C683           	MOV	R3,*SP				; SAVE WORD COUNT
  DA5A   064A           	DECT	SP
  DA5C   C682           	MOV	R2,*SP				; SAVE DESTINATION
  DA5E   0203 0500      	LI	R3,STAGING
  DA62   0202 001A      	LI	R2,SETDMA
  DA66   2DA0 E400      	CALL	@BDOS
  DA6A   0202 0014      	LI	R2,RDSEQ
  DA6E   0203 0280      	LI	R3,FCB
  DA72   2DA0 E400      	CALL	@BDOS
  DA76   C0BA           	MOV	*SP+,R2
  DA78   C0FA           	MOV	*SP+,R3
  DA7A   C17A           	MOV	*SP+,R5
  DA7C   C1FA           	MOV	*SP+,R7
  DA7E   0281 FFFF      	CI	R1,-1
  DA82   1308           	JEQ	DLDONE_B			; EOF
  DA84   0209 0100      	LI	R9,PSEL_EN
  DA88   2C89           	PSEL	R9
  DA8A   0206 0500      	LI	R6,STAGING
  DA8E   0208 0700      	LI	R8,STAGING_END
  DA92   10D6           	JMP	DLCPY
                        
                        DLDONE_B:
  DA94   04C9           	CLR	R9
  DA96   2C89           	PSEL	R9				; PSEL OFF
  DA98   C145           	MOV	R5,R5
  DA9A   131C           	JEQ	DLDONE				; NEXT_OFFSET=0: LAST BLOCK
  DA9C   A1C5           	A	R5,R7
  DA9E   C187           	MOV	R7,R6				; R6 = NEXT HEADER
  DAA0   8206           	C	R6,R8
  DAA2   1ABF           	JL	DLBLK				; IN STAGING
                        	;--- NEXT HEADER BEYOND STAGING: RELOAD ---
  DAA4   6188           	S	R8,R6				; OVERSHOOT
  DAA6   064A           	DECT	SP
  DAA8   C685           	MOV	R5,*SP
  DAAA   064A           	DECT	SP
  DAAC   C686           	MOV	R6,*SP				; SAVE OVERSHOOT
  DAAE   0203 0500      	LI	R3,STAGING
  DAB2   0202 001A      	LI	R2,SETDMA
  DAB6   2DA0 E400      	CALL	@BDOS
  DABA   0202 0014      	LI	R2,RDSEQ
  DABE   0203 0280      	LI	R3,FCB
  DAC2   2DA0 E400      	CALL	@BDOS
  DAC6   C1BA           	MOV	*SP+,R6
  DAC8   C17A           	MOV	*SP+,R5
  DACA   0208 0700      	LI	R8,STAGING_END
  DACE   0226 0500      	AI	R6,STAGING			; R6 = STAGING + OVERSHOOT
  DAD2   10A7           	JMP	DLBLK
                        
                        DLDONE:
  DAD4   2FA0 DAE4      	MESG	@DLTXT_OK
  DAD8   0460 D666      	B	@NEXTCMD
                        
  DADC   2FA0 DAFC      DLERR	MESG	@DLTXT_ERR
  DAE0   0460 D666      	B	@NEXTCMD
                        
  DAE4   4C6F 6164      DLTXT_OK	TEXT	'Loaded as overlay '
  DAE8   6564 2061      
  DAEC   7320 6F76      
  DAF0   6572 6C61      
  DAF4   7920           
  DAF6   00             	BYTE	0
  DAF7   00             	EVEN
  DAF8   0D0A 00        DLTXT_CRLF	BYTE	0DH,0AH,0
  DAFB   00             	EVEN
  DAFC   2D2D 4C6F      DLTXT_ERR	TEXT	'--Load error'
  DB00   6164 2065      
  DB04   7272 6F72      
  DB08   0D0A 00        	BYTE	0DH,0AH,0
  DB0B   00             	EVEN
                        
  DB0C   0460 D63A      TYPEFILE:	B	@RETURN
                        
                        
                        ;*******************************************************************
