  DC68   13BB           	JEQ	PLOOP
  DC6A   C120 DEB6      BUFPUT	MOV	@CMDADDR,R4
  DC6E   D501           	MOVB	R1,*R4
  DC70   9801 D018      	CB	R1,@CR
  DC74   1332           	JEQ	PEOL
  DC76   0584           	INC	R4
  DC78   C804 DEB6      	MOV	R4,@CMDADDR
  DC7C   0620 DEB8      	DEC	@CMDBYTES
  DC80   1303           	JEQ	MOVERR
  DC82   10AE           	JMP	PLOOP
  DC84   0460 DD84      BUFMOV4	B	@UNPROC
