                        ;*******************************************************************
                        ;	TYPE
                        ;*******************************************************************
                        ;*******************************************************************
                        ;	LOAD - load overlay into paged memory without executing
                        ;
                        ;	Usage: LOAD filename
                        ;	Loads the COM file, programs mapper registers per pagemap,
                        ;	copies code to paged memory, returns to shell without executing.
                        ;*******************************************************************
                        DOLOAD:
                        	;--- SKIP 'LOAD', PARSE OVERLAY FILENAME ---
  D842   0203 0250      	LI	R3,CMDLINE
  D846   9833 D015      DLSK1	CB	*R3+,@SPACE		;SKIP COMMAND NAME
  D84A   1BFD           	JH	DLSK1
  D84C   0603           	DEC	R3
  D84E   9813 D018      DLSK2	CB	*R3,@CR			;END OF LINE?
  D852   136D           	JEQ	DLERR
  D854   9833 D015      	CB	*R3+,@SPACE		;SKIP SPACES
  D858   12FA           	JLE	DLSK2
  D85A   0603           	DEC	R3
  D85C   2DA0 D1BA      	CALL	@PARSENAME		;FCB = OVERLAY NAME+EXT
                        
                        	;--- OPEN FILE ---
  D860   0204 0280      	LI	R4,FCB
  D864   04E4 001A      	CLR	@CRN(R4)
  D868   0202 000F      	LI	R2,FOPEN
  D86C   0203 0280      	LI	R3,FCB
  D870   2DA0 E400      	CALL	@BDOS
  D874   C041           	MOV	R1,R1
  D876   115B           	JLT	DLERR
                        
                        	;--- READ FIRST SECTOR ---
  D878   0203 0500      	LI	R3,STAGING
  D87C   0202 001A      	LI	R2,SETDMA
  D880   2DA0 E400      	CALL	@BDOS
  D884   0202 0014      	LI	R2,RDSEQ
  D888   0203 0280      	LI	R3,FCB
  D88C   2DA0 E400      	CALL	@BDOS
  D890   0281 FFFF      	CI	R1,-1
  D894   134C           	JEQ	DLERR
                        
                        	;--- CHECK PAGEMAP HEADER ---
  D896   0206 0500      	LI	R6,STAGING
  D89A   C016           	MOV	*R6,R0
  D89C   0280 FFFF      	CI	R0,0FFFFH
  D8A0   1646           	JNE	DLERR
  D8A2   0226 0006      	AI	R6,6			;SKIP OPENING SENTINEL
                        
                        	;--- WALK PAGEMAP ENTRIES ---
  D8A6   C016           DLPM	MOV	*R6,R0
  D8A8   0280 FFFF      	CI	R0,0FFFFH
  D8AC   130B           	JEQ	DLSENT			;CLOSING SENTINEL
  D8AE   C1F6           	MOV	*R6+,R7			;START ADDRESS
  D8B0   C076           	MOV	*R6+,R1			;END (UNUSED)
  D8B2   C136           	MOV	*R6+,R4			;PAGE NUMBER
  D8B4   C004           	MOV	R4,R0
  D8B6   13F7           	JEQ	DLPM			;PAGE 0 = SKIP
  D8B8   C247           	MOV	R7,R9
  D8BA   09C9           	SRL	R9,12			;SEGMENT = ADDR>>12
  D8BC   C004           	MOV	R4,R0
  D8BE   06A0 DE9A      	BL	@MAP_SET
  D8C2   10F1           	JMP	DLPM
                        
                        	;--- LOAD BLOCK ---
  D8C4   0226 0006      DLSENT	AI	R6,6			;SKIP CLOSING SENTINEL
  D8C8   C176           	MOV	*R6+,R5			;BLOCK SIZE (BYTES)
  D8CA   0915           	SRL	R5,1			;TO WORDS
  D8CC   C087           	MOV	R7,R2			;DESTINATION
  D8CE   0209 0100      	LI	R9,PSEL_EN
  D8D2   2C89           	PSEL	R9			;ENABLE PSEL
  D8D4   C046           	MOV	R6,R1			;SOURCE IN STAGING
  D8D6   0204 0700      	LI	R4,STAGING+512		;END OF STAGING
  D8DA   CCB1           DLCPY	MOV	*R1+,*R2+
  D8DC   0605           	DEC	R5
  D8DE   1321           	JEQ	DLDONE
  D8E0   8101           	C	R1,R4
  D8E2   1AFB           	JL	DLCPY
                        
                        	;--- NEXT SECTOR ---
  D8E4   064A           	DECT	SP
  D8E6   C682           	MOV	R2,*SP
  D8E8   064A           	DECT	SP
  D8EA   C685           	MOV	R5,*SP
  D8EC   04C9           	CLR	R9
  D8EE   2C89           	PSEL	R9			;DISABLE PSEL FOR BDOS
  D8F0   0203 0500      	LI	R3,STAGING
  D8F4   0202 001A      	LI	R2,SETDMA
  D8F8   2DA0 E400      	CALL	@BDOS
  D8FC   0202 0014      	LI	R2,RDSEQ
  D900   0203 0280      	LI	R3,FCB
  D904   2DA0 E400      	CALL	@BDOS
  D908   C17A           	MOV	*SP+,R5
  D90A   C0BA           	MOV	*SP+,R2
  D90C   0281 FFFF      	CI	R1,-1
  D910   1308           	JEQ	DLDONE
  D912   0209 0100      	LI	R9,PSEL_EN
  D916   2C89           	PSEL	R9
  D918   0201 0500      	LI	R1,STAGING
  D91C   0204 0700      	LI	R4,STAGING+512
  D920   10DC           	JMP	DLCPY
                        
  D922   04C9           DLDONE	CLR	R9
  D924   2C89           	PSEL	R9			;DISABLE PSEL
  D926   2FA0 D936      	MESG	@DLTXT_OK
  D92A   0460 D4EE      	B	@NEXTCMD
                        
  D92E   2FA0 D940      DLERR	MESG	@DLTXT_ERR
  D932   0460 D4EE      	B	@NEXTCMD
                        
  D936   4C6F 6164      DLTXT_OK	TEXT	'Loaded'
  D93A   6564           
  D93C   0D0A 00        	BYTE	0DH,0AH,0
  D93F   00             	EVEN
  D940   2D2D 4C6F      DLTXT_ERR	TEXT	'--Load error'
  D944   6164 2065      
  D948   7272 6F72      
  D94C   0D0A 00        	BYTE	0DH,0AH,0
  D94F   00             	EVEN
                        
  D950   0460 D4C2      TYPEFILE:	B	@RETURN
                        
                        
