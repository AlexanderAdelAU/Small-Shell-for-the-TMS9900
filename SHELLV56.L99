                        ;*******************************************************************
                        ;	MAP_INIT - clear all 16 map registers to page 0
                        ;	Entry: none  Exit: R0=0, R1=0, R12=MAP_WIN_BASE+32
                        ;	Called at shell cold start and LOADERCODE entry.
                        ;*******************************************************************
  DE82   04CF           MAP_INIT:	CLR	R15
  DE84   008F           	LST	R15
  DE86   020C 80C0      	LI	R12,MAP_WIN_BASE
  DE8A   04C0           	CLR	R0
  DE8C   0201 0010      	LI	R1,NUM_MAP_ENTRIES
  DE90   3080           MAPI_L:	LDCR	R0,BYTEWIDE
  DE92   05CC           	INCT	R12
  DE94   0601           	DEC	R1
  DE96   16FC           	JNE	MAPI_L
  DE98   045B           	RT
                        
                        ;*******************************************************************
                        ;	MAP_SET - program one 6116 map register
                        ;	Entry: R9=segment (0-15), R0=page (0-3)
                        ;	Exit:  R9 clobbered (segment*2), R0 clobbered, R12=CRU addr
                        ;	Note:  R8 is safe - use R8 to preserve values across MAP_SET
                        ;*******************************************************************
                        MAP_SET:
  DE9A   020C 80C0      	LI	R12,MAP_WIN_BASE
  DE9E   0A19           	SLA	R9,1			;SEGMENT * 2 = CRU BIT OFFSET
  DEA0   A309           	A	R9,R12
  DEA2   0A80           	SLA	R0,8			;MOVE PAGE TO HIGH BYTE (LDCR BYTE TRANSFER USES HIGH BYTE)
  DEA4   3080           	LDCR	R0,BYTEWIDE
  DEA6   045B           	RT
                        
  DEA8                  PPTRS	BSS	22
  DEBE                  PBUF	BSS	64
  DEFE   0000           PPADDR	WORD	0
                        
  DF00                  	END

