  D958   2DA0 D1C2      	CALL	@PARSENAME
  D95C   0202 0011      ERA4	LI	R2,SEARCH1
  D960   0203 0280      	LI	R3,FCB
  D964   2DA0 E400      	CALL	@BDOS
