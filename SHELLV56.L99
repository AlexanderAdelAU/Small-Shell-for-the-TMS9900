                        ;
                        ;*******************************************************************
                        ;
                        ;  TMS99105 SBC V4 - Memory Map
                        ;
                        ;  Address   Label      Purpose
                        ;  >0230     SH_WP      Shell Workspace: R0-R15
                        ;  >0250     SH_CMD     Command Line: raw input string
                        ;  >0280     CM_FCB     FCB (36 bytes)
                        ;  >02A4     CM_VARS    Bridge Variables: pointers, status flags
                        ;  >0300     CM_BUF     512-byte Sector Buffer / LOADERCODE area
                        ;
                        ;  Paged Memory Model (Rev 5.5):
                        ;  Segment 0  (0x0000-0x0FFF)  COMMON  - always page 0, transparent
                        ;  Segments 1-11 (0x1000-0xBFFF) PAGED - mapped via 6116 + GAL
                        ;  Segments 12-15 (0xC000-0xFFFF) PROTECTED - shell/BDOS/ROM
                        ;
                        ;  6116 mapper programmed via CRU (LDCR/STCR) at MAP_WIN_BASE.
                        ;  PSEL XOP 2 enables/disables the GAL page select output.
                        ;  With PSEL active, SA0-SA3 from 6116 gate physical RAM bank.
                        ;  XOP calls execute with PSEL disabled (transparent) - safe
                        ;  because workspace is always in segment 0 (COMMON).
                        ;
                        ;*******************************************************************
                        ;
                        ;  Original Version:
                        ;  Small/Shell 1.0 - A command processor for North Star DOS
                        ;  Copyright 1981 J.E. Hendrix, All rights reserved
                        ;  Written for PDS assembler
                        ;
                        ;  TMS9900 Port and Modern Revisions:
                        ;
                        ;  4.0   Initial TMS9900 version
                        ;  4.1   Filename extension handling (4 June 2010)
                        ;  4.6   Internal commands: DIR, SAVE, ERA
                        ;  4.7   Multisegment alignment; RETURN changed to RETF
                        ;  4.9   Intermediate paging work
                        ;
                        ;  5.4   Paged memory loader - first working version
                        ;        Transparent GAL mapping - no trampolines, no LDS/LDD
                        ;        LOADERCODE replaced with link99 v3.9 page map loader
                        ;        Sentinel detection: FFFF FFFF FFFF at file offset 6
                        ;        COM/EXE go direct to LOADERCODE (no pre-read)
                        ;        MAP_INIT called at shell entry and LOADERCODE entry
                        ;        .FILENAME load-only restored (reads flat, returns to prompt)
                        ;        R8 saves launch address across LDRCPY walk
                        ;        LDRRUN_F for raw/flat binaries
                        ;
                        ;  5.5   Paged memory loader - production version (June 2026)
                        ;        MAP_SET/MAP_INIT getter-setter pattern established
                        ;        LDRSEG calls MAP_SET - no inline CRU bit manipulation
                        ;        R8 saved in LDRPM before MAP_SET clobbers R9
                        ;        Multi-sector loading: LDRSEC direct DMA to paged memory
                        ;        BDOS passes DMA address unchanged through page mapper
                        ;        INT2_HANDLER: full debug dump (PC/WP/ST + map registers)
                        ;        INT2_VEC installed before every paged launch
                        ;        Paged execution confirmed: HELLO runs from seg 2 page 2
                        ;        Transparent memory model: XOPs safe from paged code
                        ;        Segment 0 COMMON always page 0 - workspace always visible
                        ;
                        ;*******************************************************************
                        
  0000                  R0	EQU	0
  0001                  R1	EQU	1
  0002                  R2	EQU	2
  0003                  R3	EQU	3
  0004                  R4	EQU	4
  0005                  R5	EQU	5
  0006                  R6	EQU	6
  0007                  R7	EQU	7
  0008                  R8	EQU	8
  0009                  R9	EQU	9
  000A                  R10	EQU	10
  000B                  R11	EQU	11
  000C                  R12	EQU	12
  000D                  WP	EQU	13
  000D                  R13	EQU	13
  000E                  R14	EQU	14
  000F                  R15	EQU	15
  000A                  SP	EQU	10
                        ;
                        ;----Define  Extended Operations
                        ;
                        	DXOP	PSEL,2			;ENABLE/DISABLE PAGE MAPPER
                        	DXOP	PUSHREG,4
                        	DXOP	POPREG,5
                        	DXOP	CALL,6
                        	DXOP	RET,7
                        	DXOP	PUSH,8
                        	DXOP	POP,9
                        	DXOP	WHEX,10			;WRITE OUT A 16 BIT HEX VALUE
                        	DXOP	RHEX,11			;READ IN A 16 BIT HEX VALUE
                        	DXOP	WRITE,12		;WRITE CHAR IN MSB
                        	DXOP	READ,13			;READ CHAR IN MSB
                        	DXOP	MESG,14			;OUTPUT NULL TERMINATED MESSAGE
                        	DXOP	DEBUG,15
                        ;
                        ; OPERATING SYSTEM EQUATES
                        ;
  D000                  SHELL:		EQU	0D000H
  E400                  BDOS:		EQU	0E400H
  F000                  MONITOR:	EQU	0F000H
  F004                  BANNER:		EQU	MONITOR + 4
                        
  80C0                  MAP_WIN_BASE:	 EQU	080C0H		;6116 MAP REGISTER CRU BASE
  0010                  NUM_MAP_ENTRIES: EQU	16		;16 PAGE REGISTERS
                        
                        ;
                        ; WORKSPACE AND MEMORY LAYOUT
                        ;
  0230                  WORKSP:		EQU	0230H		;SHELL WORKSPACE
  1000                  STACKP:		EQU	1000H			;STACK AT 0x1000, GROWS DOWN
  0500                  TPA:		EQU	0500H
  0250                  CMDLINE:	EQU	0250H
  10FF                  HALT:		EQU	10FFH
  0300                  COMM_BUF:	EQU	0300H		;COMMON BUFFER / LOADERCODE AREA
  0280                  COMM_FCB:	EQU	0280H
  0280                  FCB:		EQU	COMM_FCB
                        ;
                        ; SHELL ENTRY POINT
                        ;
                        	;*******************************************************************
                        	;  BDOS SWAP XOP 0 - Lives in COMMON (0x0100-0x013F)
                        	;
                        	;  Installed by SHELL INIT into XOP 0 vector at 0x0040.
                        	;  Called from cbdos.a99 via DXOP BDOS_CALL,0
                        	;
                        	;  XOP mechanism:
                        	;    - Saves caller WP->R13, PC->R14, ST->R15 in THIS workspace
                        	;    - Switches to BDOS_XWP workspace
                        	;    - Disables PSEL automatically
                        	;    - RTWP restores caller context
                        	;
                        	;  Handler reads caller R2/R3 via @(R13), writes result to caller R1
                        	;*******************************************************************
  0100                  	AORG	BDOS_XWP			;0x0100 - XOP 0 WORKSPACE
  0100                  		BSS	32			;16 WORDS FOR XOP 0 WORKSPACE
                        
  0120                  	AORG	BDOS_XOP_E			;0x0120 - XOP 0 HANDLER
  0120   2E8D           		WHEX	R13			;DEBUG - CALLER WP
  0122   2E8E           		WHEX	R14			;DEBUG - CALLER PC
                        	;--- READ CALLER R2 (FUNCTION) AND R3 (PARAM) ---
  0124   C0AD 0004      		MOV	@4(R13),R2		;CALLER R2 = BDOS FUNCTION CODE
  0128   C0ED 0006      		MOV	@6(R13),R3		;CALLER R3 = BDOS PARAMETER
                        	;--- SAVE CURRENT SEGMENT 13 PAGE MAPPING ---
  012C   020C 80DC      		LI	R12,BDOS_CRU		;CRU ADDR FOR SEGMENT 13
  0130   04C1           		CLR	R1
  0132   3481           		STCR	R1,BYTEWIDE		;READ CURRENT PAGE INTO R1
  0134   C201           		MOV	R1,R8			;SAVE IN R8 (OWN WORKSPACE)
                        	;--- MAP BDOS PAGE INTO SEGMENT 13 ---
  0136   0201 000E      		LI	R1,BDOS_PAGE
                        		;LDCR writes from LSB - page number used directly
  013A   3081           		LDCR	R1,BYTEWIDE		;PROGRAM SEGMENT 13 = BDOS PAGE
                        	;--- ENABLE PSEL ---
  013C   0209 0100      		LI	R9,PSEL_EN
  0140   2C89           		PSEL	R9
                        	;--- CALL BDOS ---
  0142   2DA0 E000      		CALL	@BDOS_VIRT		;CALL INTO 0xD000
                        	;--- SAVE BDOS RESULT BEFORE RESTORING MAPPER ---
  0146   C1C1           		MOV	R1,R7			;SAVE BDOS RESULT IN R7
                        	;--- DISABLE PSEL TO SAFELY REPROGRAM MAPPER ---
  0148   04C9           		CLR	R9
  014A   2C89           		PSEL	R9
                        	;--- RESTORE PREVIOUS SEGMENT 13 MAPPING ---
  014C   C048           		MOV	R8,R1			;SAVED PAGE (ALREADY IN HIGH BYTE FROM STCR)
  014E   020C 80DC      		LI	R12,BDOS_CRU
  0152   3081           		LDCR	R1,BYTEWIDE		;RESTORE SEGMENT 13 (HIGH BYTE = PAGE)
                        	;--- RE-ENABLE PSEL ---
  0154   0209 0100      		LI	R9,PSEL_EN
  0158   2C89           		PSEL	R9
                        	;--- PUT BDOS RETURN VALUE INTO CALLER R1 ---
  015A   CB47 0002      		MOV	R7,@2(R13)		;R1 OF CALLER WORKSPACE = BDOS RESULT
                        	;--- RETURN FROM XOP ---
  015E   0380           		RTWP
                        
  D000                  	AORG	SHELL
  D000   02E0 0230      	LWPI	WORKSP
  D004   020A 1000      	LI	SP,STACKP
  D008   06A0 DE82      	BL	@MAP_INIT		;CLEAR ALL MAP REGISTERS TO PAGE 0
  D00C   0460 D026      	B	@INIT
                        ;
                        ; LOW MEMORY EQUATES
                        ;
  00A0                  CMDL_PTR:	EQU	0A0H
  00A2                  CMDL_SIZE:	EQU	0A2H
  00A4                  BUFF_PTR:	EQU	0A4H
  00A8                  LBA:		EQU	0A8H
  00AC                  FCB_PTR:	EQU	0ACH
  00A6                  FREEMEM:	EQU	0A6H
  00B0                  MEMLIMIT:	EQU	0B0H
  0200                  BUFFSIZ:	EQU	512
                        ;
  0080                  SHELL_PTR:	EQU	80H
  0084                  BDOS_PTR:	EQU	84H
  0300                  LOADER:		EQU	0300H
  0040                  CLSZ:		EQU	64
  0200                  BYTSEC:		EQU	512
  0002                  BYTEWIDE:	EQU	2			;CRU BITS PER MAP REGISTER
  0010                  NUM_SEGS:	EQU	16			;NUMBER OF MAP SEGMENTS
  000C                  PROT_SEG:	EQU	12			;FIRST PROTECTED SEGMENT
  1000                  SEG_SIZE:	EQU	1000H			;4KB SEGMENT SIZE
  0100                  PSEL_EN:	EQU	0100H			;PSEL ENABLE VALUE
  000A                  INT2_VEC:	EQU	000AH			;INT2 VECTOR ADDRESS
  000E                  BDOS_PAGE:	EQU	14			;PHYSICAL PAGE WHERE BDOS LIVES
  000E                  BDOS_SEG:	EQU	14			;VIRTUAL SEGMENT FOR BDOS (0xE000)
  E000                  BDOS_VIRT:	EQU	0E000H			;BDOS VIRTUAL ADDRESS (UNCHANGED)
  80DC                  BDOS_CRU:	EQU	MAP_WIN_BASE+(BDOS_SEG*2)	;CRU ADDR FOR SEG 14 = 0x80DC
  0040                  XOP0_WP:	EQU	0040H			;XOP 0 VECTOR - WORKSPACE PTR
  0042                  XOP0_PC:	EQU	0042H			;XOP 0 VECTOR - HANDLER PC
  0100                  BDOS_XWP:	EQU	0100H			;BDOS XOP WORKSPACE (32 BYTES)
  0120                  BDOS_XOP_E:	EQU	0120H			;BDOS XOP HANDLER ENTRY
  0500                  STAGING:	EQU	0500H			;SECTOR STAGING BUFFER
  02A0                  OVL_PRINT_VEC:	EQU	02A0H			;OVERLAY PRINT CALLBACK VECTOR (PAGE VARIABLES AREA)
  1000                  FLATBASE:	EQU	1000H			;DEFAULT FLAT LOAD ADDRESS
                        
  0100                  IDE_BYTSEC:	EQU	256
                        
                        ;
                        ; BDOS FUNCTION CODES
                        ;
  0001                  CIN	EQU	1
  0002                  COUT	EQU	2
  000E                  SELDSK	EQU	14
  0014                  RDSEQ	EQU	20
  000F                  FOPEN	EQU	15
  0010                  FCLOSE	EQU	16
  0011                  SEARCH1	EQU	17
  0012                  SEARCH2	EQU	18
  0013                  ERAFIL	EQU	19
  0015                  WRSEQ	EQU	21
  0016                  MAKFIL	EQU	22
  001A                  SETDMA	EQU	26
  0000                  HDERR	EQU	0
  0000                  DOSERR	EQU	0
                        ;
                        ; FCB OFFSETS
                        ;
  0000                  NAM	EQU	0
  000B                  FTY	EQU	11
  0010                  FLA	EQU	16
  001A                  CRN	EQU	26
  0018                  CBN	EQU	24
  001C                  RELB	EQU	28
  001E                  RELR	EQU	30
  000C                  FSB	EQU	12
  000E                  FSZ	EQU	14
                        ;
                        ; FILE TYPES
                        ;
  0001                  COM	EQU	1
  0002                  EXE	EQU	2
  0003                  TXT	EQU	3
  0004                  BAS	EQU	4
  0005                  PRO	EQU	5
                        ;
                        ; ASSEMBLY CONSTANTS
                        ;
  0200                  BLKSIZ	EQU	512
  000B                  NAMSIZ	EQU	11
  0003                  EXTSIZ	EQU	3
  0001                  DDEN	EQU	1
  0001                  DCOMR	EQU	1
  0000                  PAD	EQU	0
  0008                  EXTOFF	EQU	NAMSIZ-EXTSIZ
  D010   03             CTLC	BYTE	03H
  D011   18             CTLX	BYTE	18H
  D012   13             CTLS	BYTE	13H
  D013   19             CTLY	BYTE	19H
  D014   1A             CTLZ	BYTE	1AH
  D015   20             SPACE	BYTE	20H
  D016   00             	BYTE	0
  D017   08             BS	BYTE	08H
  D018   0D             CR	BYTE	0DH
  D019   0A             LF	BYTE	0AH
  D01A   07             DEL	BYTE	07H
  D01B   FF             EOF	BYTE	0FFH
  D01C   3A             COMT	BYTE	3AH
  D01D   2E             JUMP	BYTE	'.'
  D01E   2E             NULPARM	BYTE	'.'
  D01F   2E             EXT	BYTE	'.'
  D020   5F             NOTE	BYTE	'_'
  D021   25             PROM	BYTE	'%'
  D022   24             SUBMARK	BYTE	'$'
  D023   2A             SYSFILE	BYTE	'*'
  D024   2B             DOSCMD	BYTE	'+'
  0000                  CONSOLE	EQU	0
  0002                  EXEC	EQU	2
  0005                  PROC	EQU	5
  0000                  DEFDRV	EQU	0
  D025   00             	EVEN
                        
                        ;*******************************************************************
                        ;	INIT - cold start initialisation
                        ;*******************************************************************
  D026                  	EVEN
  D026   02E0 0230      INIT	LWPI	WORKSP
  D02A   020A 1000      	LI	SP,STACKP
                        
                        	;--- INIT 7 INTERRUPT VECTORS TO SAFE RTWP HANDLER ---
  D02E   0200 0230      	LI	R0,WORKSP		;WP FOR INTERRUPT HANDLER
  D032   0201 DE1C      	LI	R1,INT_SAFE		;PC = SAFE RTWP HANDLER
  D036   0202 00B0      	LI	R2,00B0H		;FIRST INTERRUPT VECTOR
  D03A   0203 0007      	LI	R3,7			;7 VECTORS
  D03E   CC80           INIT_IV	MOV	R0,*R2+			;STORE WP
  D040   CC81           	MOV	R1,*R2+			;STORE PC
  D042   0603           	DEC	R3
  D044   16FC           	JNE	INIT_IV
                        
  D046   0201 0250      	LI	R1,CMDLINE
  D04A   0202 DD14      	LI	R2,CMDLINE2
  D04E   DC72           CMDLOOP:	MOVB	*R2+,*R1+
  D050   16FE           	JNE	CMDLOOP
                        
  D052   D820 D018      	MOVB	@CR,@CMDLINE
  D056   0250           
  D058   0200 0250      	LI	R0,CMDLINE
  D05C   C800 00A0      	MOV	R0,@CMDL_PTR
  D060   04E0 00A2      	CLR	@CMDL_SIZE
  D064   0200 0300      	LI	R0,COMM_BUF
  D068   C800 00A4      	MOV	R0,@BUFF_PTR
  D06C   0200 0280      	LI	R0,COMM_FCB
  D070   C800 00AC      	MOV	R0,@FCB_PTR
                        
  D074   0200 0460      INIT22	LI	R0,0460H
  D078   0201 D4C2      	LI	R1,RETURN
  D07C   C800 0080      	MOV	R0,@SHELL_PTR
  D080   C801 0082      	MOV	R1,@SHELL_PTR+2
                        
  D084   0200 0460      	LI	R0,0460H
  D088   0201 E400      	LI	R1,BDOS
  D08C   C800 0084      	MOV	R0,@BDOS_PTR
  D090   C801 0086      	MOV	R1,@BDOS_PTR+2
                        
                        	;--- INSTALL BDOS SWAP XOP 0 AT 0x0040 ---
  D094   0200 0100      	LI	R0,BDOS_XWP			;WORKSPACE ADDRESS IN COMMON
  D098   C800 0040      	MOV	R0,@XOP0_WP			;XOP 0 WORKSPACE POINTER
  D09C   0200 0120      	LI	R0,BDOS_XOP_E			;HANDLER ADDRESS IN COMMON
  D0A0   C800 0042      	MOV	R0,@XOP0_PC			;XOP 0 PC POINTER
                        
  D0A4   0200 0500      	LI	R0,TPA
  D0A8   C800 00A6      	MOV	R0,@FREEMEM
  D0AC   0200 D000      	LI	R0,SHELL
  D0B0   C800 00B0      	MOV	R0,@MEMLIMIT
                        
  D0B4   2FA0 DD74      	MESG	@SINON
                        
                        ;*******************************************************************
                        ;	DOCMD - process next shell command
                        ;*******************************************************************
  D0B8   C020 DD08      DOCMD	MOV	@SKIPSW,R0
  D0BC   04E0 DD08      	CLR	@SKIPSW
  D0C0   C000           	MOV	R0,R0
  D0C2   1617           	JNE	DOCMD2A
  D0C4   0203 0250      	LI	R3,CMDLINE
  D0C8   04C1           	CLR	R1
  D0CA   D053           	MOVB	*R3,R1
  D0CC   9801 D018      	CB	R1,@CR
  D0D0   1310           	JEQ	DOCMD2A
                        
  D0D2   0281 0000      CHKSYS	CI	R1,0
  D0D6   1602           	JNE	DOCMD1
  D0D8   0460 DB92      	B	@CMDERR
                        
  D0DC   9801 D011      DOCMD1	CB	R1,@CTLX
  D0E0   1602           	JNE	DOCMDAA
  D0E2   0420 F004      	BLWP	@BANNER
  D0E6   9801 D013      DOCMDAA	CB	R1,@CTLY
  D0EA   1600           	JNE	DOCMD2
                        
  D0EC   9801 D015      DOCMD2	CB	R1,@SPACE
  D0F0   1B02           	JH	DOCMD4
                        
  D0F2   0460 D4EE      DOCMD2A	B	@NEXTCMD
                        
  D0F6   9801 D01D      DOCMD4	CB	R1,@JUMP
  D0FA   1607           	JNE	DOCMD3
  D0FC   0203 0251      	LI	R3,CMDLINE+1
  D100   9813 D015      	CB	*R3,@SPACE
  D104   1B07           	JH	LOOK
  D106   0460 D2DE      	B	@GOPROG
                        
  D10A   9801 D024      DOCMD3	CB	R1,@DOSCMD
  D10E   1602           	JNE	LOOK
  D110   0460 D4C2      DOCMD9	B	@RETURN
                        
                        ;*******************************************************************
                        ;	LOOK - look up named file
                        ;*******************************************************************
  D114   2DA0 D1BA      LOOK:	CALL	@PARSENAME
  D118   2DA0 D5C2      	CALL	@ICMD
  D11C   2DA0 D1B4      	CALL	@SEG_SWITCH
                        
  D120   9820 0288      	CB	@FCB+EXTOFF,@SPACE
  D124   D015           
  D126   1608           	JNE	L_START
                        
  D128   0200 D1EC      	LI	R0,EXT_TAB
  D12C   D830 0288      L_TRY:	MOVB	*R0+,@FCB+EXTOFF
  D130   D830 0289      	MOVB	*R0+,@FCB+EXTOFF + 1
  D134   D830 028A      	MOVB	*R0+,@FCB+EXTOFF + 2
                        
  D138   0203 0280      L_START:	LI	R3,FCB
  D13C   0202 0011      	LI	R2,SEARCH1
  D140   2DA0 E400      	CALL	@BDOS
  D144   C041           	MOV	R1,R1
  D146   1408           	JHE	L_FOUND
                        
  D148   9820 0288      	CB	@FCB+EXTOFF,@SPACE
  D14C   D015           
  D14E   0280 D1F8      	CI	R0,EXT_END
  D152   1AEC           	JL	L_TRY
                        
  D154   0460 DB92      LOOKERR:	B	@CMDERR
                        
  D158   0202 000F      L_FOUND:	LI	R2,FOPEN
  D15C   0203 0280      	LI	R3,FCB
  D160   2DA0 E400      	CALL	@BDOS
  D164   C041           	MOV	R1,R1
  D166   11F6           	JLT	LOOKERR
  D168   0204 0280      	LI	R4,FCB
  D16C   C824 000E      	MOV	@FSZ(R4),@MFSZ
  D170   DD66           
  D172   D824 000B      	MOVB	@FTY(R4),@MFTY
  D176   DD64           
  D178   0460 D21C      	B	@LOAD
                        
                        ;*******************************************************************
                        ;	PADSPACE - R2=count, R4=destination
                        ;*******************************************************************
  D17C   C082           PADSPACE:	MOV	R2,R2
  D17E   1204           	JLE	PADRETS
  D180   DD20 D015      PADLOOP:	MOVB	@SPACE,*R4+
  D184   0602           	DEC	R2
  D186   1BFC           	JH	PADLOOP
  D188   2DC0           PADRETS:	RET
                        
                        ;*******************************************************************
                        ;	CHKCHAR - check if char at *R3 is valid filename char
                        ;*******************************************************************
  D18A   D053           CHKCHAR:	MOVB	*R3,R1
  D18C   0981           	SRL	R1,8
  D18E   0281 0030      	CI	R1,'0'
  D192   1A0C           	JL	INVALID
  D194   0281 0039      	CI	R1,'9'
  D198   1207           	JLE	VALID
  D19A   0241 00DF      	ANDI	R1,00DFH
  D19E   0221 FFBF      	AI	R1,-'A'
  D1A2   0281 001A      	CI	R1,001AH
  D1A6   1B02           	JH	INVALID
  D1A8   04C1           VALID:	CLR	R1
  D1AA   1002           	JMP	SETFLAG
  D1AC   0201 0001      INVALID:	LI	R1,1
  D1B0   C041           SETFLAG:	MOV	R1,R1
  D1B2   2DC0           	RET
                        
                        ;*******************************************************************
                        ;	SEG_SWITCH - deprecated v5.4 (transparent GAL mapping)
                        ;*******************************************************************
  D1B4   2DC0           SEG_SWITCH:	RET
                        
  D1B6   0460 D6B2      SSWERR:	B	@PARSERR
                        
                        ;*******************************************************************
                        ;	PARSENAME - parse filename from command line into FCB
                        ;*******************************************************************
  D1BA   0204 0280      PARSENAME:	LI	R4,FCB
  D1BE   0202 0008      	LI	R2,NAMSIZ - EXTSIZ
  D1C2   04C0           	CLR	R0
                        
  D1C4   2DA0 D18A      PARSE1:	CALL	@CHKCHAR
  D1C8   1604           	JNE	FILLNAME
  D1CA   DD33           	MOVB	*R3+,*R4+
  D1CC   0602           	DEC	R2
  D1CE   1303           	JEQ	FINDDOT
  D1D0   10F9           	JMP	PARSE1
                        
  D1D2   2DA0 D17C      FILLNAME:	CALL	@PADSPACE
                        
  D1D6   9833 D01F      FINDDOT:	CB	*R3+,@EXT
  D1DA   130F           	JEQ	GETEXT
  D1DC   0603           	DEC	R3
  D1DE   0202 0003      	LI	R2,EXTSIZ
  D1E2   0204 0288      	LI	R4,FCB + NAMSIZ - EXTSIZ
  D1E6   2DA0 D17C      	CALL	@PADSPACE
  D1EA   2DC0           	RET
                        
  D1EC   434F 4D42      EXT_TAB:	TEXT	'COMBASBAT'
  D1F0   4153 4241      
  D1F4   54             
  D1F5   54             CHRT:	BYTE	'T'
  D1F6   4D             CHRM:	BYTE	'M'
  D1F7   53             CHRS:	BYTE	'S'
  D1F8   00             EXT_END:	BYTE	0
  D1F9   00             	EVEN
                        
  D1FA   0202 0003      GETEXT:	LI	R2,EXTSIZ
  D1FE   0204 0288      	LI	R4,FCB + NAMSIZ - EXTSIZ
  D202   2DA0 D18A      NEXTEXT:	CALL	@CHKCHAR
  D206   1607           	JNE	FILLEXT
  D208   D073           	MOVB	*R3+,R1
  D20A   0241 DF00      	ANDI	R1,0DF00H
  D20E   DD01           	MOVB	R1,*R4+
  D210   0602           	DEC	R2
  D212   1301           	JEQ	FILLEXT
  D214   10F6           	JMP	NEXTEXT
  D216   2DA0 D17C      FILLEXT:	CALL	@PADSPACE
  D21A   2DC0           	RET
                        
                        ;*******************************************************************
                        ;	LOAD - load executable file
                        ;
                        ;	FLA in FCB gives load address (0 = use TPA).
                        ;	'.' prefix = flat load only, no execution, returns to prompt.
                        ;	COM/EXE/type 0 = LOADERCODE (handles paged and raw binaries).
                        ;*******************************************************************
  D21C   04C1           LOAD:	CLR	R1
  D21E   D801 024E      	MOVB	R1,@CMDLINE-2
  D222   0204 0280      	LI	R4,FCB
  D226   C0E4 0010      	MOV	@FLA(R4),R3
  D22A   1602           	JNE	LOAD2
  D22C   0203 0500      	LI	R3,TPA
  D230   C803 DD10      LOAD2	MOV	R3,@LADDR
  D234   04E4 001A      	CLR	@CRN(R4)
                        
  D238   9820 0250      	CB	@CMDLINE,@JUMP
  D23C   D01D           
  D23E   1617           	JNE	LOADRUN
  D240   064A           LOADF3	DECT	SP
  D242   C683           	MOV	R3,*SP
  D244   0202 001A      LOADF0	LI	R2,SETDMA
  D248   2DA0 E400      	CALL	@BDOS
  D24C   0202 0014      	LI	R2,RDSEQ
  D250   0203 0280      	LI	R3,FCB
  D254   2DA0 E400      	CALL	@BDOS
  D258   C0FA           	MOV	*SP+,R3
  D25A   0281 FFFF      	CI	R1,-1
  D25E   1303           	JEQ	LOADF1
  D260   0223 0200      	AI	R3,BLKSIZ
  D264   10ED           	JMP	LOADF3
  D266   C803 00A6      LOADF1	MOV	R3,@FREEMEM
  D26A   0460 D4EE      	B	@NEXTCMD
                        
                        LOADRUN:
  D26E   D060 DD64      	MOVB	@MFTY,R1
  D272   0981           	SRL	R1,8
  D274   0281 0001      	CI	R1,COM
  D278   1602           	JNE	LT2
  D27A   0460 D2DE      	B	@GOPROG
  D27E   0281 0002      LT2	CI	R1,EXE
  D282   1602           	JNE	LT3
  D284   0460 D2DE      	B	@GOPROG
  D288   0281 0000      LT3	CI	R1,0
  D28C   1602           	JNE	LT4
  D28E   0460 D2DE      	B	@GOPROG
                        LT4
  D292   04E4 001A      	CLR	@CRN(R4)
  D296   064A           LOAD3	DECT	SP
  D298   C683           	MOV	R3,*SP
  D29A   0202 001A      LOAD0	LI	R2,SETDMA
  D29E   2DA0 E400      	CALL	@BDOS
  D2A2   0202 0014      	LI	R2,RDSEQ
  D2A6   0203 0280      	LI	R3,FCB
  D2AA   2DA0 E400      	CALL	@BDOS
  D2AE   C0FA           	MOV	*SP+,R3
  D2B0   0281 FFFF      	CI	R1,-1
  D2B4   1303           	JEQ	LOAD1
  D2B6   0223 0200      	AI	R3,BLKSIZ
  D2BA   10ED           	JMP	LOAD3
  D2BC   C803 00A6      LOAD1	MOV	R3,@FREEMEM
  D2C0   D060 DD64      	MOVB	@MFTY,R1
  D2C4   0981           	SRL	R1,8
  D2C6   0281 0005      	CI	R1,PROC
  D2CA   1602           	JNE	LOAD1B
  D2CC   0460 D4EE      	B	@NEXTCMD
  D2D0   0281 0003      LOAD1B	CI	R1,TXT
  D2D4   1602           	JNE	LOAD1C
  D2D6   0460 D4EE      	B	@NEXTCMD
  D2DA   0460 D4EE      LOAD1C	B	@NEXTCMD
                        
                        ;*******************************************************************
                        ;	GOPROG - run loaded program via LOADERCODE
                        ;*******************************************************************
  D2DE   0204 0250      GOPROG	LI	R4,CMDLINE
  D2E2   0584           GOLOOP	INC	R4
  D2E4   9814 D015      	CB	*R4,@SPACE
  D2E8   1BFC           	JH	GOLOOP
  D2EA   04C1           	CLR	R1
  D2EC   D801 024F      	MOVB	R1,@CMDLINE-1
  D2F0   0200 0080      	LI	R0,SHELL_PTR
  D2F4   064A           	DECT	SP
  D2F6   C680           	MOV	R0,*SP
  D2F8   2DA0 D300      	CALL	@INIT_LOADER
  D2FC   0460 0300      	B	@LOADER
                        
                        ;*******************************************************************
                        ;	INIT_LOADER - copy LOADERCODE to LOADER (0x0300)
                        ;*******************************************************************
  D300   0202 0300      INIT_LOADER:	LI	R2,LOADER
  D304   0201 D312      	LI	R1,LOADERCODE
  D308   CCB1           IL0:	MOV	*R1+,*R2+
  D30A   0281 D4C2      	CI	R1,END_LOADER
  D30E   1AFC           	JL	IL0
  D310   2DC0           	RET
                        
                        ;*******************************************************************
                        ;  LOADERCODE v5.6
                        ;
                        ;  Copied to LOADER (0x0300) by INIT_LOADER, runs from COMMON.
                        ;
                        ;  STAGING buffer: 0x0500, 512 bytes, always in common memory.
                        ;  First sector always read to STAGING for format detection.
                        ;  LADDR: FCB load address - used only for raw binary.
                        ;
                        ;  File format detection (first word of staging buffer):
                        ;    FFFF = link99 format:
                        ;           FFFF FFFF FFFF   opening sentinel
                        ;           start end page   pagemap entry (one entry for now)
                        ;           FFFF FFFF FFFF   closing sentinel
                        ;           size data...     one block
                        ;    else = raw binary: load flat to LADDR, launch from LADDR
                        ;
                        ;  Paged load sequence:
                        ;    1. Clear all map registers to page 0
                        ;    2. Read first sector to STAGING
                        ;    3. Detect format
                        ;    4. Walk pagemap entries, call MAP_SET for each segment
                        ;    5. Enable PSEL once after all MAP_SET calls
                        ;    6. Copy block to destination (LDRCPY/LDRSEC)
                        ;    7. Launch from R8 (first pagemap entry start)
                        ;
                        ;  Key registers:
                        ;    R1   source in STAGING (reset each sector reload)
                        ;    R2   paged destination (walks continuously)
                        ;    R3   words remaining (saved/restored across BDOS via stack)
                        ;    R4   end of STAGING = 0x0700
                        ;    R6   walks STAGING: pagemap then block data
                        ;    R7   segment walker in LDRSEG
                        ;    R8   launch address (first pagemap entry start)
                        ;    R9   scratch / PSEL value
                        ;*******************************************************************
                        
                        LOADERCODE:
                        
                        ;--- CLEAR ALL MAP REGISTERS TO PAGE 0 ---
  D312   020C 80C0      	LI	R12,MAP_WIN_BASE
  D316   04C0           	CLR	R0
  D318   0201 0010      	LI	R1,NUM_SEGS
  D31C   3080           LDRCL:	LDCR	R0,BYTEWIDE
  D31E   05CC           	INCT	R12
  D320   0601           	DEC	R1
  D322   16FC           	JNE	LDRCL
                        
                        ;--- READ FIRST SECTOR TO STAGING (0x0500) ---
  D324   04C0           	CLR	R0
  D326   0203 0500      	LI	R3,0500H		;STAGING BUFFER
  D32A   0202 001A      	LI	R2,SETDMA
  D32E   2DA0 E400      	CALL	@BDOS
  D332   0202 0014      	LI	R2,RDSEQ
  D336   0203 0280      	LI	R3,FCB
  D33A   2DA0 E400      	CALL	@BDOS
  D33E   0281 FFFF      	CI	R1,-1
  D342   1602           	JNE	LDRDET
  D344   0460 D480      	B	@LDRRUN_F		;EMPTY FILE
  D348   C041           LDRDET:	MOV	R1,R1
  D34A   1101           	JLT	LDRDET_ERR
  D34C   1002           	JMP	LDRDET1
                        LDRDET_ERR:
  D34E   0460 D49A      	B	@LDRERR
                        LDRDET1:
                        
                        ;--- DETECT FORMAT ---
                        ;  First word FFFF = link99 format (opening sentinel)
                        ;  Anything else  = raw binary
  D352   0206 0500      	LI	R6,0500H		;START OF STAGING
  D356   C016           	MOV	*R6,R0
  D358   0280 FFFF      	CI	R0,0FFFFH
  D35C   1601           	JNE	LDRDET2			;NOT FFFF = RAW BINARY
  D35E   1002           	JMP	LDRPM
  D360   0460 D432      LDRDET2:	B	@LDRRAW
                        
                        ;--- WALK PAGEMAP ---
                        ;  R6 points at current sentinel on first entry and after each entry
                        ;  LDRPM:  skip sentinel then peek at next word
                        ;  LDRPM1: re-entry point after processing an entry (R6 at next sentinel)
  D364   0226 0006      LDRPM:	AI	R6,6			;SKIP SENTINEL - R6 NOW AT ENTRY OR CLOSING SENTINEL
  D368   C016           LDRPM1:	MOV	*R6,R0
  D36A   0280 FFFF      	CI	R0,0FFFFH
  D36E   1314           	JEQ	LDRSENT			;CLOSING SENTINEL = END OF PAGEMAP
  D370   C1F6           	MOV	*R6+,R7			;R7 = START ADDRESS
  D372   C207           	MOV	R7,R8			;R8 = LAUNCH ADDRESS (FIRST ENTRY)
  D374   C076           	MOV	*R6+,R1			;R1 = END ADDRESS
  D376   C136           	MOV	*R6+,R4			;R4 = PAGE NUMBER
  D378   C004           	MOV	R4,R0
  D37A   13F6           	JEQ	LDRPM1			;PAGE 0 = FLAT - SKIP MAP_SET - R6 AT NEXT SENTINEL
                        
  D37C   C007           LDRSEG:	MOV	R7,R0
  D37E   09C0           	SRL	R0,12			;SEGMENT = ADDR >> 12
  D380   0280 000C      	CI	R0,PROT_SEG
  D384   1404           	JHE	LDRPROT
  D386   C240           	MOV	R0,R9			;R9 = SEGMENT
  D388   C004           	MOV	R4,R0			;R0 = PAGE
  D38A   06A0 DE9A      	BL	@MAP_SET
                        LDRPROT:
  D38E   0227 1000      	AI	R7,SEG_SIZE
  D392   8047           	C	R7,R1
  D394   1AF3           	JL	LDRSEG
  D396   10E8           	JMP	LDRPM1			;NEXT ENTRY - R6 ALREADY AT NEXT SENTINEL
                        
                        ;--- CLOSING SENTINEL: ENABLE PSEL, SET UP COPY ---
                        LDRSENT:
  D398   0226 0006      	AI	R6,6			;SKIP CLOSING SENTINEL
  D39C   C088           	MOV	R8,R2			;R2 = COPY DESTINATION
  D39E   0209 0100      	LI	R9,PSEL_EN
  D3A2   2C89           	PSEL	R9			;ENABLE PSEL ONCE
                        
                        ;--- READ BLOCK SIZE AND SET UP WORD COUNT ---
  D3A4   C156           LDRBLK:	MOV	*R6,R5
  D3A6   0285 FFFF      	CI	R5,0FFFFH
  D3AA   132E           	JEQ	LDRRUN
  D3AC   0285 0000      	CI	R5,0
  D3B0   132B           	JEQ	LDRRUN
  D3B2   05C6           	INCT	R6			;SKIP SIZE WORD
  D3B4   C046           	MOV	R6,R1			;R1 = SOURCE
  D3B6   0915           	SRL	R5,1			;BYTES TO WORDS
  D3B8   C0C5           	MOV	R5,R3			;R3 = WORD COUNT
  D3BA   0204 0700      	LI	R4,0700H		;R4 = END OF STAGING
                        
                        ;--- COPY WORDS: STAGING -> PAGED MEMORY (PSEL ACTIVE) ---
  D3BE   CCB1           LDRCPY:	MOV	*R1+,*R2+
  D3C0   0603           	DEC	R3
  D3C2   1322           	JEQ	LDRRUN			;ALL WORDS DONE
  D3C4   8101           	C	R1,R4
  D3C6   1AFB           	JL	LDRCPY			;MORE IN STAGING
                        
                        ;--- STAGING EXHAUSTED: RELOAD NEXT SECTOR TO STAGING ---
                        ;  Stack saves are safe - BDOS uses own workspace via CALL XOP
  D3C8   064A           LDRSEC:	DECT	SP
  D3CA   C688           	MOV	R8,*SP			;SAVE LAUNCH ADDRESS
  D3CC   064A           	DECT	SP
  D3CE   C682           	MOV	R2,*SP			;SAVE PAGED DESTINATION
  D3D0   064A           	DECT	SP
  D3D2   C683           	MOV	R3,*SP			;SAVE WORD COUNT
  D3D4   0203 0500      	LI	R3,0500H		;DMA TO STAGING
  D3D8   0202 001A      	LI	R2,SETDMA
  D3DC   2DA0 E400      	CALL	@BDOS
  D3E0   0202 0014      	LI	R2,RDSEQ
  D3E4   0203 0280      	LI	R3,FCB
  D3E8   2DA0 E400      	CALL	@BDOS
  D3EC   C0FA           	MOV	*SP+,R3			;RESTORE WORD COUNT
  D3EE   C0BA           	MOV	*SP+,R2			;RESTORE PAGED DESTINATION
  D3F0   C23A           	MOV	*SP+,R8			;RESTORE LAUNCH ADDRESS
  D3F2   0281 FFFF      	CI	R1,-1
  D3F6   1308           	JEQ	LDRRUN			;EOF - ALL DATA LOADED
  D3F8   0209 0100      	LI	R9,PSEL_EN		;RE-ENABLE PSEL
  D3FC   2C89           	PSEL	R9
  D3FE   0201 0500      	LI	R1,0500H		;RESET SOURCE TO START OF STAGING
  D402   0204 0700      	LI	R4,0700H		;RESET END OF STAGING
  D406   10DB           	JMP	LDRCPY			;RESUME COPY
                        
                        ;--- LAUNCH PAGED PROGRAM ---
  D408   C020 D5BC      LDRRUN:	MOV	@LOAD_ONLY,R0		;LOAD ONLY?
  D40C   1609           	JNE	LDRRUN_LOAD		;YES - SKIP EXECUTE
  D40E   0200 DE1E      	LI	R0,INT2_HANDLER
  D412   C800 000A      	MOV	R0,@INT2_VEC
  D416   04CF           	CLR	R15
  D418   026F 0007      	ORI	R15,0007H		;ST7=0=PRIVILEGED, INTERRUPT MASK=7
  D41C   008F           	LST	R15
  D41E   0458           	B	*R8
                        LDRRUN_LOAD:
  D420   04C9           	CLR	R9
  D422   2C89           	PSEL	R9			;DISABLE PSEL
  D424   04C0           	CLR	R0
  D426   C800 D5BC      	MOV	R0,@LOAD_ONLY		;CLEAR FLAG
  D42A   2FA0 D4B8      	MESG	@TXT_LOADED		;CONFIRM LOAD
  D42E   0460 D4EE      	B	@NEXTCMD		;BACK TO SHELL PROMPT
                        
                        ;--- RAW BINARY: LOAD TO LADDR, LAUNCH FROM LADDR ---
  D432   C260 DD10      LDRRAW:	MOV	@LADDR,R9		;R9 = LAUNCH ADDRESS
  D436   0203 0500      	LI	R3,0500H		;COPY STAGING -> LADDR
  D43A   C120 DD10      	MOV	@LADDR,R4
  D43E   CD33           LDRRAW1:MOV	*R3+,*R4+
  D440   0283 0700      	CI	R3,0700H		;END OF STAGING
  D444   1AFC           	JL	LDRRAW1
  D446   C0E0 DD10      	MOV	@LADDR,R3
  D44A   0223 0200      	AI	R3,BYTSEC		;NEXT SECTOR
                        
  D44E   064A           LDRRAWS:DECT	SP
  D450   C683           	MOV	R3,*SP
  D452   0202 001A      	LI	R2,SETDMA
  D456   2DA0 E400      	CALL	@BDOS
  D45A   0202 0014      	LI	R2,RDSEQ
  D45E   0203 0280      	LI	R3,FCB
  D462   2DA0 E400      	CALL	@BDOS
  D466   C0FA           	MOV	*SP+,R3
  D468   0281 FFFF      	CI	R1,-1
  D46C   1602           	JNE	LDRRAWS1
  D46E   0460 D480      	B	@LDRRUN_F
                        LDRRAWS1:
  D472   C041           	MOV	R1,R1
  D474   1103           	JLT	LDRRAWS_ERR
  D476   0223 0200      	AI	R3,BYTSEC
  D47A   10E9           	JMP	LDRRAWS
                        LDRRAWS_ERR:
  D47C   0460 D49A      	B	@LDRERR
                        
                        ;--- LAUNCH RAW/FLAT (NO PSEL) ---
                        LDRRUN_F:
  D480   C020 D5BC      	MOV	@LOAD_ONLY,R0		;LOAD ONLY?
  D484   16CD           	JNE	LDRRUN_LOAD		;YES - SKIP EXECUTE
  D486   0200 DE1E      	LI	R0,INT2_HANDLER		;INSTALL INT2 DEBUG HANDLER
  D48A   C800 000A      	MOV	R0,@INT2_VEC
  D48E   04CF           	CLR	R15
  D490   026F 0007      	ORI	R15,0007H		;ST7=0=PRIVILEGED, INTERRUPT MASK=7
  D494   008F           	LST	R15
  D496   C089           	MOV	R9,R2
  D498   0452           	B	*R2
                        
  D49A   2FA0 D4A2      LDRERR:	MESG	@TXT_LDRERR
  D49E   0460 D4C2      	B	@RETURN
                        
  D4A2   2D2D 4C6F      TXT_LDRERR:	TEXT	'--Loader read error'
  D4A6   6164 6572      
  D4AA   2072 6561      
  D4AE   6420 6572      
  D4B2   726F 72        
  D4B5   0D0A 00        		BYTE	0DH,0AH,0
  D4B8                  		EVEN
  D4B8   4C6F 6164      TXT_LOADED:	TEXT	'Loaded'
  D4BC   6564           
  D4BE   0D0A 00        		BYTE	0DH,0AH,0
  D4C1   00             		EVEN
                        
  D4C2                  END_LOADER:	EQU	$+0
                        ;*******************************************************************
                        ;	RETURN - program exit
                        ;*******************************************************************
  D4C2   06A0 DE82      RETURN:	BL	@MAP_INIT
  D4C6   D801 024E      	MOVB	R1,@CMDLINE-2
  D4CA   02E0 0230      	LWPI	WORKSP
  D4CE   020A 1000      	LI	SP,STACKP
  D4D2   04CF           	CLR	R15
  D4D4   D060 024E      	MOVB	@CMDLINE-2,R1
  D4D8   0881           	SRA	R1,8
  D4DA   0281 FFFF      	CI	R1,-1
  D4DE   1607           	JNE	NEXTCMD
  D4E0   04C1           	CLR	R1
  D4E2   D801 024E      	MOVB	R1,@CMDLINE-2
  D4E6   C041           	MOV	R1,R1
  D4E8   1302           	JEQ	NEXTCMD
  D4EA   0460 DBCA      	B	@UNPROC
                        
                        ;*******************************************************************
                        ;	NEXTCMD / PROMPT
                        ;*******************************************************************
  D4EE   D060 DD06      NEXTCMD	MOVB	@PROCSW,R1
  D4F2   1302           	JEQ	PROMPT
  D4F4   0460 DA10      	B	@PFETCH
                        
  D4F8   D0E0 D021      PROMPT:	MOVB	@PROM,R3
  D4FC   2DA0 DCC4      	CALL	@OUTCHAR
  D500   0204 0250      	LI	R4,CMDLINE
  D504   0205 0040      	LI	R5,CLSZ
  D508   C060 0000      CINLOOP	MOV	@CONSOLE,R1
  D50C   2DA0 DCB8      	CALL	@INCHAR
  D510   9801 D017      	CB	R1,@BS
  D514   132A           	JEQ	RUBOUT
  D516   9801 D01A      	CB	R1,@DEL
  D51A   1327           	JEQ	RUBOUT
  D51C   9801 D010      	CB	R1,@CTLC
  D520   1604           	JNE	STOWIT
  D522   D060 D018      	MOVB	@CR,R1
  D526   D801 0250      	MOVB	R1,@CMDLINE
                        
  D52A   C001           STOWIT	MOV	R1,R0
  D52C   0980           	SRL	R0,8
  D52E   0280 0061      	CI	R0,61H
  D532   1A08           	JL	STOWIT2
  D534   0280 007A      	CI	R0,7AH
  D538   1B05           	JH	STOWIT2
  D53A   0220 FFE0      	AI	R0,-20H
  D53E   06C0           	SWPB	R0
  D540   DD00           	MOVB	R0,*R4+
  D542   1001           	JMP	STOWIT2+2
  D544   DD01           STOWIT2	MOVB	R1,*R4+
  D546   0605           	DEC	R5
  D548   1224           	JLE	CIOERR
  D54A   9801 D015      	CB	R1,@SPACE
  D54E   1404           	JHE	ECHO
  D550   04C0           	CLR	R0
  D552   D060 D018      	MOVB	@CR,R1
  D556   D500           	MOVB	R0,*R4
  D558   C0C1           ECHO	MOV	R1,R3
  D55A   2DA0 DCC4      	CALL	@OUTCHAR
  D55E   04E0 DD08      	CLR	@SKIPSW
  D562   9801 D019      	CB	R1,@LF
  D566   130E           	JEQ	GODOCMD
  D568   10CF           	JMP	CINLOOP
  D56A   0285 0040      RUBOUT	CI	R5,CLSZ
  D56E   14CC           	JHE	CINLOOP
  D570   0585           	INC	R5
  D572   0604           	DEC	R4
  D574   064A           	DECT	SP
  D576   C684           	MOV	R4,*SP
  D578   0204 DDD2      	LI	R4,RUBMSG
  D57C   2DA0 DCEE      	CALL	@OUTSTR
  D580   C13A           	MOV	*SP+,R4
  D582   10C2           	JMP	CINLOOP
  D584   0200 0250      GODOCMD	LI	R0,CMDLINE
  D588   6100           	S	R0,R4
  D58A   C804 00A2      	MOV	R4,@CMDL_SIZE
  D58E   0460 D0B8      	B	@DOCMD
  D592   0460 DB98      CIOERR	B	@LINERR
                        
                        ;*******************************************************************
                        ;	INTERNAL COMMANDS
                        ;*******************************************************************
  0005                  CMDCNT	EQU	5
  D596   4449 52        ICLIST	TEXT	"DIR"
  D599   00             	BYTE	0
  D59A   D614           	WORD	DSKDIR
  D59C   5341 5645      	TEXT	"SAVE"
  D5A0   00             	BYTE	0
  D5A1   D6B6           	WORD	DSKSAVE
  D5A3   4552 41        	TEXT	"ERA"
  D5A6   00             	BYTE	0
  D5A7   D7B6           	WORD	ERAFILE
  D5A9   5459 5045      	TEXT	"TYPE"
  D5AD   00             	BYTE	0
  D5AE   D950           	WORD	TYPEFILE
  D5B0   4C4F 4144      	TEXT	"LOAD"
  D5B4   00             	BYTE	0
  D5B5   D842           	WORD	DOLOAD
  D5B7   00             	EVEN
                        
  D5B8   0000           BUFPNT	WORD	0
  D5BA   0000           RECCNT	WORD	0
  D5BC   0000           LOAD_ONLY:	WORD	0			;NON-ZERO = LOAD WITHOUT EXECUTE
  D5BE   0000           SADDR	WORD	0
  D5C0   2D             SWITCH	BYTE	'-'
  D5C1   00             	EVEN
                        
  D5C2   0201 D596      ICMD	LI	R1,ICLIST
  D5C6   0204 0280      	LI	R4,FCB
  D5CA   0205 0005      	LI	R5,CMDCNT
  D5CE   9C74           ICMD0	CB	*R4+,*R1+
  D5D0   13FE           	JEQ	ICMD0
