                        ;
                        ;*******************************************************************
                        ;
                        ;  TMS99105 SBC V4 - Memory Map
                        ;
                        ;  Address   Label      Purpose
                        ;  >0230     SH_WP      Shell Workspace: R0-R15
                        ;  >0250     SH_CMD     Command Line: raw input string
                        ;  >0280     CM_FCB     FCB (36 bytes)
                        ;  >02A4     CM_VARS    Bridge Variables: pointers, status flags
                        ;  >0300     CM_BUF     512-byte Sector Buffer / LOADERCODE area
                        ;
                        ;  Paged Memory Model (Rev 5.5):
                        ;  Segment 0  (0x0000-0x0FFF)  COMMON  - always page 0, transparent
                        ;  Segments 1-11 (0x1000-0xBFFF) PAGED - mapped via 6116 + GAL
                        ;  Segments 12-15 (0xC000-0xFFFF) PROTECTED - shell/BDOS/ROM
                        ;
                        ;  6116 mapper programmed via CRU (LDCR/STCR) at MAP_WIN_BASE.
                        ;  PSEL XOP 2 enables/disables the GAL page select output.
                        ;  With PSEL active, SA0-SA3 from 6116 gate physical RAM bank.
                        ;  XOP calls execute with PSEL disabled (transparent) - safe
                        ;  because workspace is always in segment 0 (COMMON).
                        ;
                        ;*******************************************************************
                        ;
                        ;  Original Version:
                        ;  Small/Shell 1.0 - A command processor for North Star DOS
                        ;  Copyright 1981 J.E. Hendrix, All rights reserved
                        ;  Written for PDS assembler
                        ;
                        ;  TMS9900 Port and Modern Revisions:
                        ;
                        ;  4.0   Initial TMS9900 version
                        ;  4.1   Filename extension handling (4 June 2010)
                        ;  4.6   Internal commands: DIR, SAVE, ERA
                        ;  4.7   Multisegment alignment; RETURN changed to RETF
                        ;  4.9   Intermediate paging work
                        ;
                        ;  5.4   Paged memory loader - first working version
                        ;        Transparent GAL mapping - no trampolines, no LDS/LDD
                        ;        LOADERCODE replaced with link99 v3.9 page map loader
                        ;        Sentinel detection: FFFF FFFF FFFF at file offset 6
                        ;        COM/EXE go direct to LOADERCODE (no pre-read)
                        ;        MAP_INIT called at shell entry and LOADERCODE entry
                        ;        .FILENAME load-only restored (reads flat, returns to prompt)
                        ;        R8 saves launch address across LDRCPY walk
                        ;        LDRRUN_F for raw/flat binaries
                        ;
                        ;  5.5   Paged memory loader - production version (June 2026)
                        ;        MAP_SET/MAP_INIT getter-setter pattern established
                        ;        LDRSEG calls MAP_SET - no inline CRU bit manipulation
                        ;        R8 saved in LDRPM before MAP_SET clobbers R9
                        ;        Multi-sector loading: LDRSEC direct DMA to paged memory
                        ;        BDOS passes DMA address unchanged through page mapper
                        ;        INT2_HANDLER: full debug dump (PC/WP/ST + map registers)
                        ;        INT2_VEC installed before every paged launch
                        ;        Paged execution confirmed: HELLO runs from seg 2 page 2
                        ;        Transparent memory model: XOPs safe from paged code
                        ;        Segment 0 COMMON always page 0 - workspace always visible
                        ;
                        ;  5.7   EXE paged chain format support (June 2026)
                        ;        EXE FILE FORMAT (link99 -Pn chain format, produced by link99 v3.9.10+):
                        ;          Each block: next_offset(w) page(w) start(w) size(w) [data]
                        ;          next_offset=0 = last block. page=0 = common/flat.
                        ;          Loader does single forward pass: MAP_SET, PSEL, copy, follow chain.
                        ;          Link command: link99 -O1000 -M out.EXE base.R99 mgr.R99 -P2 ovla.R99
                        ;          -O1000 sets cbase=1000H for base modules (TPA for EXE files).
                        ;          Overlay modules use AORG 2000H; linked with -Pn for page assignment.
                        ;
                        ;        SHELL CHANGES:
                        ;          EXT_TAB: added EXE (type 2), removed dead CHRT/CHRM/CHRS bytes
                        ;          L_TRY: save/restore R0 across BDOS (BDOS clobbers R0)
                        ;                 MOVB *R0,R1 / JNE loop termination (replaces CI R0,EXT_END)
                        ;          SET_FTY: new subroutine - derives file type from FCB extension
                        ;                   uses R5/R6 auto-increment, SWPB+MOVB store
                        ;                   called from L_FOUND and LOADRUN (not raw FCB FTY byte)
                        ;          LOADRUN: CALL @SET_FTY replaces MOVB @FTY(R4) - reliable type detect
                        ;          DOLOAD: rewritten for chain block format (old sentinel format removed)
                        ;                  supports multi-block overlays with sector reload
                        ;          LOADERCODE_EXE: two-sector staging (EXE_STG to EXE_STG_END)
                        ;                          no mid-block reload needed for typical EXE files
                        ;                          all staging addresses via named EQUs (no hardcoding)
                        ;          MSAVE: new word - preserves R0 across BDOS in L_TRY loop
                        ;
                        ;        LINKER REQUIREMENTS (link99 v3.9.10+):
                        ;          Fix 1: Phase 1 PREL - AORG modules (field>=PAGE_SEG) skip cmod add
                        ;          Fix 2: Phase 2 PREL - AORG modules (field>=PAGE_SEG) skip cbase add
                        ;          Fix 3: resolve() - subtract cbase from xrloc for buffer offset
                        ;
                        ;        BDOS CHANGES (BDOS57):
                        ;          GETTYPE rewritten: EXE added (type 2), type numbering corrected
                        ;          COM=1 EXE=2 TXT=3 BAS=4 PRO=5 - matches shell constants
                        ;          Uses R5/R6 auto-increment pattern, GT_TAB replaces CHRT/CHRM/CHRS
                        ;
                        ;*******************************************************************
                        
  0000                  R0	EQU	0
  0001                  R1	EQU	1
  0002                  R2	EQU	2
  0003                  R3	EQU	3
  0004                  R4	EQU	4
  0005                  R5	EQU	5
  0006                  R6	EQU	6
  0007                  R7	EQU	7
  0008                  R8	EQU	8
  0009                  R9	EQU	9
  000A                  R10	EQU	10
  000B                  R11	EQU	11
  000C                  R12	EQU	12
  000D                  WP	EQU	13
  000D                  R13	EQU	13
  000E                  R14	EQU	14
  000F                  R15	EQU	15
  000A                  SP	EQU	10
                        ;
                        ;----Define  Extended Operations
                        ;
                        	DXOP	PSEL,2			;ENABLE/DISABLE PAGE MAPPER
                        	DXOP	PUSHREG,4
                        	DXOP	POPREG,5
                        	DXOP	CALL,6
                        	DXOP	RET,7
                        	DXOP	PUSH,8
                        	DXOP	POP,9
                        	DXOP	WHEX,10			;WRITE OUT A 16 BIT HEX VALUE
                        	DXOP	RHEX,11			;READ IN A 16 BIT HEX VALUE
                        	DXOP	WRITE,12		;WRITE CHAR IN MSB
                        	DXOP	READ,13			;READ CHAR IN MSB
                        	DXOP	MESG,14			;OUTPUT NULL TERMINATED MESSAGE
                        	DXOP	DEBUG,15
                        ;
                        ; OPERATING SYSTEM EQUATES
                        ;
  D000                  SHELL:		EQU	0D000H
  E400                  BDOS:		EQU	0E400H
  F000                  MONITOR:	EQU	0F000H
  F004                  BANNER:		EQU	MONITOR + 4
                        
  80C0                  MAP_WIN_BASE:	 EQU	080C0H		;6116 MAP REGISTER CRU BASE
  0010                  NUM_MAP_ENTRIES: EQU	16		;16 PAGE REGISTERS
                        
                        ;
                        ; WORKSPACE AND MEMORY LAYOUT
                        ;
  0230                  WORKSP:		EQU	0230H		;SHELL WORKSPACE
  1000                  STACKP:		EQU	1000H			;STACK AT 0x1000, GROWS DOWN
  0500                  TPA:		EQU	0500H
  0250                  CMDLINE:	EQU	0250H
  10FF                  HALT:		EQU	10FFH
  0300                  COMM_BUF:	EQU	0300H		;COMMON BUFFER / LOADERCODE AREA
  0280                  COMM_FCB:	EQU	0280H
  0280                  FCB:	EQU	COMM_FCB
                        ;
                        ; SHELL ENTRY POINT
                        ;
                        	;*******************************************************************
                        	;  BDOS SWAP XOP 0 - Lives in COMMON (0x0100-0x013F)
                        	;
                        	;  Installed by SHELL INIT into XOP 0 vector at 0x0040.
                        	;  Called from cbdos.a99 via DXOP BDOS_CALL,0
                        	;
                        	;  XOP mechanism:
                        	;    - Saves caller WP->R13, PC->R14, ST->R15 in THIS workspace
                        	;    - Switches to BDOS_XWP workspace
                        	;    - Disables PSEL automatically
                        	;    - RTWP restores caller context
                        	;
                        	;  Handler reads caller R2/R3 via @(R13), writes result to caller R1
                        	;*******************************************************************
  0100                  	AORG	BDOS_XWP			;0x0100 - XOP 0 WORKSPACE
  0100                  		BSS	32			;16 WORDS FOR XOP 0 WORKSPACE
                        
  0120                  	AORG	BDOS_XOP_E			;0x0120 - XOP 0 HANDLER
                        	;--- READ CALLER R2 (FUNCTION) AND R3 (PARAM) ---
  0120   C0AD 0004      		MOV	@4(R13),R2		;CALLER R2 = BDOS FUNCTION CODE
  0124   C0ED 0006      		MOV	@6(R13),R3		;CALLER R3 = BDOS PARAMETER
                        	;--- SAVE CURRENT SEGMENT 13 PAGE MAPPING ---
  0128   020C 80DC      		LI	R12,BDOS_CRU		;CRU ADDR FOR SEGMENT 13
  012C   04C1           		CLR	R1
  012E   3481           		STCR	R1,BYTEWIDE		;READ CURRENT PAGE INTO R1
  0130   C201           		MOV	R1,R8			;SAVE IN R8 (OWN WORKSPACE)
                        	;--- MAP BDOS PAGE INTO SEGMENT 13 ---
  0132   0201 000E      		LI	R1,BDOS_PAGE
                        		;LDCR writes from LSB - page number used directly
  0136   3081           		LDCR	R1,BYTEWIDE		;PROGRAM SEGMENT 13 = BDOS PAGE
                        	;--- ENABLE PSEL ---
  0138   0209 0100      		LI	R9,PSEL_EN
  013C   2C89           		PSEL	R9
                        	;--- CALL BDOS ---
  013E   2DA0 E000      		CALL	@BDOS_VIRT		;CALL INTO 0xD000
                        	;--- SAVE BDOS RESULT BEFORE RESTORING MAPPER ---
  0142   C1C1           		MOV	R1,R7			;SAVE BDOS RESULT IN R7
                        	;--- DISABLE PSEL TO SAFELY REPROGRAM MAPPER ---
  0144   04C9           		CLR	R9
  0146   2C89           		PSEL	R9
                        	;--- RESTORE PREVIOUS SEGMENT 13 MAPPING ---
  0148   C048           		MOV	R8,R1			;SAVED PAGE (ALREADY IN HIGH BYTE FROM STCR)
  014A   020C 80DC      		LI	R12,BDOS_CRU
  014E   3081           		LDCR	R1,BYTEWIDE		;RESTORE SEGMENT 13 (HIGH BYTE = PAGE)
                        	;--- RE-ENABLE PSEL ---
  0150   0209 0100      		LI	R9,PSEL_EN
  0154   2C89           		PSEL	R9
                        	;--- PUT BDOS RETURN VALUE INTO CALLER R1 ---
  0156   CB47 0002      		MOV	R7,@2(R13)		;R1 OF CALLER WORKSPACE = BDOS RESULT
                        	;--- RETURN FROM XOP ---
  015A   0380           		RTWP
                        
  D000                  	AORG	SHELL
  D000   02E0 0230      	LWPI	WORKSP
  D004   020A 1000      	LI	SP,STACKP
  D008   06A0 E03C      	BL	@MAP_INIT		;CLEAR ALL MAP REGISTERS TO PAGE 0
  D00C   0460 D026      	B	@INIT
                        ;
                        ; LOW MEMORY EQUATES
                        ;
  00A0                  CMDL_PTR:	EQU	0A0H
  00A2                  CMDL_SIZE:	EQU	0A2H
  00A4                  BUFF_PTR:	EQU	0A4H
  00A8                  LBA:		EQU	0A8H
  00AC                  FCB_PTR:	EQU	0ACH
  00A6                  FREEMEM:	EQU	0A6H
  00B0                  MEMLIMIT:	EQU	0B0H
  0200                  BUFFSIZ:	EQU	512
                        ;
  0080                  SHELL_PTR:	EQU	80H
  0084                  BDOS_PTR:	EQU	84H
  0300                  LOADER:		EQU	0300H
  0040                  CLSZ:		EQU	64
  0200                  BYTSEC:		EQU	512
  0002                  BYTEWIDE:	EQU	2			;CRU BITS PER MAP REGISTER
  0010                  NUM_SEGS:	EQU	16			;NUMBER OF MAP SEGMENTS
  000C                  PROT_SEG:	EQU	12			;FIRST PROTECTED SEGMENT
  1000                  SEG_SIZE:	EQU	1000H			;4KB SEGMENT SIZE
  0100                  PSEL_EN:	EQU	0100H			;PSEL ENABLE VALUE
  000A                  INT2_VEC:	EQU	000AH			;INT2 VECTOR ADDRESS
  000E                  BDOS_PAGE:	EQU	14			;PHYSICAL PAGE WHERE BDOS LIVES
  000E                  BDOS_SEG:	EQU	14			;VIRTUAL SEGMENT FOR BDOS (0xE000)
  E000                  BDOS_VIRT:	EQU	0E000H			;BDOS VIRTUAL ADDRESS (UNCHANGED)
  80DC                  BDOS_CRU:	EQU	MAP_WIN_BASE+(BDOS_SEG*2)	;CRU ADDR FOR SEG 14 = 0x80DC
  0040                  XOP0_WP:	EQU	0040H			;XOP 0 VECTOR - WORKSPACE PTR
  0042                  XOP0_PC:	EQU	0042H			;XOP 0 VECTOR - HANDLER PC
  0100                  BDOS_XWP:	EQU	0100H			;BDOS XOP WORKSPACE (32 BYTES)
  0120                  BDOS_XOP_E:	EQU	0120H			;BDOS XOP HANDLER ENTRY
  0500                  STAGING:	EQU	0500H			;SECTOR STAGING BUFFER (COM LOADER)
  0500                  EXE_STG:	EQU	0500H			;EXE LOADER STAGING BASE
  0700                  EXE_STG2:	EQU	0700H			;EXE LOADER SECOND SECTOR
  0900                  EXE_STG_END:	EQU	0900H			;EXE LOADER STAGING END (2 x 512 BYTES)
  0700                  STAGING_END:	EQU	STAGING+512		;COM/DOLOAD STAGING END (1 x 512 BYTES)
                        ;--- OVERLAY MANAGER PAGE VARIABLES (0x02A0-0x02FF) ---
  02A0                  OVL_PRINT_VEC:	EQU	02A0H			; WORD: APPLICATION PRINT CALLBACK
  02A2                  OVL_INIT_VEC:	EQU	02A2H			; WORD: ADDRESS OF OVLMGR_INIT
  02A4                  OVL_SWAP_VEC:	EQU	02A4H			; WORD: ADDRESS OF OVLMGR
  02A6                  OVL_COUNT:	EQU	02A6H			; WORD: NUMBER OF OVERLAYS REGISTERED BY LOADER
  02A8                  OVL_CURR_ID:	EQU	02A8H			; WORD: CURRENTLY MAPPED OVLID (0=NONE)
  02AA                  OVL_CURR_SEG:	EQU	02AAH			; WORD: CURRENTLY MAPPED SEGMENT
  02AC                  OVL_PAGE_TAB:	EQU	02ACH			; 16 WORDS: PHYSICAL PAGE PER OVLID 1-16
  02CC                  OVL_SEG_TAB:	EQU	02CCH			; 16 WORDS: VIRTUAL SEGMENT PER OVLID 1-16
  0A00                  OVLMGR_BASE:	EQU	0A00H			; OVLMGR RESIDENT IN COMMON AT 0A00H
  1000                  FLATBASE:	EQU	1000H			;DEFAULT FLAT LOAD ADDRESS
                        
  0100                  IDE_BYTSEC:	EQU	256
                        
                        ;
                        ; BDOS FUNCTION CODES
                        ;
  0001                  CIN	EQU	1
  0002                  COUT	EQU	2
  000E                  SELDSK	EQU	14
  0014                  RDSEQ	EQU	20
  000F                  FOPEN	EQU	15
  0010                  FCLOSE	EQU	16
  0011                  SEARCH1	EQU	17
  0012                  SEARCH2	EQU	18
  0013                  ERAFIL	EQU	19
  0015                  WRSEQ	EQU	21
  0016                  MAKFIL	EQU	22
  001A                  SETDMA	EQU	26
  0000                  HDERR	EQU	0
  0000                  DOSERR	EQU	0
                        ;
                        ; FCB OFFSETS
                        ;
  0000                  NAM	EQU	0
  000B                  FTY	EQU	11
  0010                  FLA	EQU	16
  001A                  CRN	EQU	26
  0018                  CBN	EQU	24
  001C                  RELB	EQU	28
  001E                  RELR	EQU	30
  000C                  FSB	EQU	12
  000E                  FSZ	EQU	14
                        ;
                        ; FILE TYPES
                        ;
  0000                  SYS	EQU	0
  0001                  COM	EQU	1
  0002                  EXE	EQU	2
  0003                  TXT	EQU	3
  0004                  BAS	EQU	4
  0005                  PRO	EQU	5
                        ;
                        ; ASSEMBLY CONSTANTS
                        ;
  0200                  BLKSIZ	EQU	512
  000B                  NAMSIZ	EQU	11
  0003                  EXTSIZ	EQU	3
  0001                  DDEN	EQU	1
  0001                  DCOMR	EQU	1
  0000                  PAD	EQU	0
  0008                  EXTOFF	EQU	NAMSIZ-EXTSIZ
  D010   03             CTLC	BYTE	03H
  D011   18             CTLX	BYTE	18H
  D012   13             CTLS	BYTE	13H
  D013   19             CTLY	BYTE	19H
  D014   1A             CTLZ	BYTE	1AH
  D015   20             SPACE	BYTE	20H
  D016   00             	BYTE	0
  D017   08             BS	BYTE	08H
  D018   0D             CR	BYTE	0DH
  D019   0A             LF	BYTE	0AH
  D01A   07             DEL	BYTE	07H
  D01B   FF             EOF	BYTE	0FFH
  D01C   3A             COMT	BYTE	3AH
  D01D   2E             JUMP	BYTE	'.'
  D01E   2E             NULPARM	BYTE	'.'
  D01F   2E             EXT	BYTE	'.'
  D020   5F             NOTE	BYTE	'_'
  D021   25             PROM	BYTE	'%'
  D022   24             SUBMARK	BYTE	'$'
  D023   2A             SYSFILE	BYTE	'*'
  D024   2B             DOSCMD	BYTE	'+'
  0000                  CONSOLE	EQU	0
  0000                  DEFDRV	EQU	0
  D025   00             	EVEN
                        
                        ;*******************************************************************
                        ;	INIT - cold start initialisation
                        ;*******************************************************************
  D026                  	EVEN
  D026   02E0 0230      INIT	LWPI	WORKSP
  D02A   020A 1000      	LI	SP,STACKP
                        
                        	;--- INIT 7 INTERRUPT VECTORS TO SAFE RTWP HANDLER ---
  D02E   0200 0230      	LI	R0,WORKSP		;WP FOR INTERRUPT HANDLER
  D032   0201 DFD6      	LI	R1,INT_SAFE		;PC = SAFE RTWP HANDLER
  D036   0202 00B0      	LI	R2,00B0H		;FIRST INTERRUPT VECTOR
  D03A   0203 0007      	LI	R3,7			;7 VECTORS
  D03E   CC80           INIT_IV	MOV	R0,*R2+			;STORE WP
  D040   CC81           	MOV	R1,*R2+			;STORE PC
  D042   0603           	DEC	R3
  D044   16FC           	JNE	INIT_IV
                        
                        	;--- INIT OVERLAY MANAGER ---
                        	; Copy OVLMGR code to common at 0A00H, install vectors
  D046   06A0 D4C8      	BL	@COPY_OVLMGR
  D04A   04C0           	CLR	R0
  D04C   C800 02A6      	MOV	R0,@OVL_COUNT
  D050   C800 02A8      	MOV	R0,@OVL_CURR_ID
  D054   C800 02AA      	MOV	R0,@OVL_CURR_SEG
                        
  D058   0201 0250      	LI	R1,CMDLINE
  D05C   0202 DECE      	LI	R2,CMDLINE2
  D060   DC72           CMDLOOP:	MOVB	*R2+,*R1+
  D062   16FE           	JNE	CMDLOOP
                        
  D064   D820 D018      	MOVB	@CR,@CMDLINE
  D068   0250           
  D06A   0200 0250      	LI	R0,CMDLINE
  D06E   C800 00A0      	MOV	R0,@CMDL_PTR
  D072   04E0 00A2      	CLR	@CMDL_SIZE
  D076   0200 0300      	LI	R0,COMM_BUF
  D07A   C800 00A4      	MOV	R0,@BUFF_PTR
  D07E   0200 0280      	LI	R0,COMM_FCB
  D082   C800 00AC      	MOV	R0,@FCB_PTR
                        
  D086   0200 0460      INIT22	LI	R0,0460H
  D08A   0201 D63A      	LI	R1,RETURN
  D08E   C800 0080      	MOV	R0,@SHELL_PTR
  D092   C801 0082      	MOV	R1,@SHELL_PTR+2
                        
  D096   0200 0460      	LI	R0,0460H
  D09A   0201 E400      	LI	R1,BDOS
  D09E   C800 0084      	MOV	R0,@BDOS_PTR
  D0A2   C801 0086      	MOV	R1,@BDOS_PTR+2
                        
                        	;--- INSTALL BDOS SWAP XOP 0 AT 0x0040 ---
  D0A6   0200 0100      	LI	R0,BDOS_XWP			;WORKSPACE ADDRESS IN COMMON
  D0AA   C800 0040      	MOV	R0,@XOP0_WP			;XOP 0 WORKSPACE POINTER
  D0AE   0200 0120      	LI	R0,BDOS_XOP_E			;HANDLER ADDRESS IN COMMON
  D0B2   C800 0042      	MOV	R0,@XOP0_PC			;XOP 0 PC POINTER
                        
  D0B6   0200 0500      	LI	R0,TPA
  D0BA   C800 00A6      	MOV	R0,@FREEMEM
  D0BE   0200 D000      	LI	R0,SHELL
  D0C2   C800 00B0      	MOV	R0,@MEMLIMIT
                        
  D0C6   2FA0 DF2E      	MESG	@SINON
                        
                        ;*******************************************************************
                        ;	DOCMD - process next shell command
                        ;*******************************************************************
  D0CA   C020 DEC2      DOCMD	MOV	@SKIPSW,R0
  D0CE   04E0 DEC2      	CLR	@SKIPSW
  D0D2   C000           	MOV	R0,R0
  D0D4   1617           	JNE	DOCMD2A
  D0D6   0203 0250      	LI	R3,CMDLINE
  D0DA   04C1           	CLR	R1
  D0DC   D053           	MOVB	*R3,R1
  D0DE   9801 D018      	CB	R1,@CR
  D0E2   1310           	JEQ	DOCMD2A
                        
  D0E4   0281 0000      CHKSYS	CI	R1,0
  D0E8   1602           	JNE	DOCMD1
  D0EA   0460 DD4C      	B	@CMDERR
                        
  D0EE   9801 D011      DOCMD1	CB	R1,@CTLX
  D0F2   1602           	JNE	DOCMDAA
  D0F4   0420 F004      	BLWP	@BANNER
  D0F8   9801 D013      DOCMDAA	CB	R1,@CTLY
  D0FC   1600           	JNE	DOCMD2
                        
  D0FE   9801 D015      DOCMD2	CB	R1,@SPACE
  D102   1B02           	JH	DOCMD4
                        
  D104   0460 D666      DOCMD2A	B	@NEXTCMD
                        
  D108   9801 D01D      DOCMD4	CB	R1,@JUMP
  D10C   1607           	JNE	DOCMD3
  D10E   0203 0251      	LI	R3,CMDLINE+1
  D112   9813 D015      	CB	*R3,@SPACE
  D116   1B07           	JH	LOOK
  D118   0460 D31A      	B	@GOPROG
                        
  D11C   9801 D024      DOCMD3	CB	R1,@DOSCMD
  D120   1602           	JNE	LOOK
  D122   0460 D63A      DOCMD9	B	@RETURN
                        
                        ;*******************************************************************
                        ;	LOOK - look up named file
                        ;*******************************************************************
  D126   2DA0 D1C2      LOOK:	CALL	@PARSENAME
  D12A   2DA0 D73A      	CALL	@ICMD
  D12E   2DA0 D1BC      	CALL	@SEG_SWITCH
                        ;CHECK IF JUST FILE NAME TYPES IN
  D132   9820 0288      	CB	@FCB+EXTOFF,@SPACE
  D136   D015           
  D138   1608           	JNE	L_START
                        ;YES ADD WILD CARD
  D13A   0200 3F00      	LI	R0,'?'*256 ;EXT_TAB
  D13E   D800 0288      L_TRY:	MOVB	R0,@FCB+EXTOFF
  D142   D800 0289      	MOVB	R0,@FCB+EXTOFF+1
  D146   D800 028A      	MOVB	R0,@FCB+EXTOFF+2
                        
  D14A   2E00           L_START:	PUSH	R0		; SAVE R0 - BDOS CLOBBERS IT
  D14C   0203 0280      	LI	R3,FCB
  D150   0202 0011      	LI	R2,SEARCH1
  D154   2DA0 E400      	CALL	@BDOS
  D158   2E40           	POP	R0		; RESTORE R0
  D15A   C041           	MOV	R1,R1
  D15C   1404           	JHE	L_FOUND
                        
  D15E   D050           	MOVB	*R0,R1		; PEEK AT NEXT ENTRY - SETS CC
  D160   16EE           	JNE	L_TRY
                        
  D162   0460 DD4C      LOOKERR:	B	@CMDERR
                        
  D166   0202 000F      L_FOUND:	LI	R2,FOPEN
  D16A   0203 0280      	LI	R3,FCB
  D16E   2DA0 E400      	CALL	@BDOS
  D172   C041           	MOV	R1,R1
  D174   11F6           	JLT	LOOKERR
  D176   0204 0280      	LI	R4,FCB
  D17A   C824 000E      	MOV	@FSZ(R4),@MFSZ
  D17E   DF20           
                        ;	CALL	@SET_FTY			; DERIVE FTY FROM EXTENSION
  D180   0460 D258      	B	@LOAD
                        
                        ;*******************************************************************
                        ;	PADSPACE - R2=count, R4=destination
                        ;*******************************************************************
  D184   C082           PADSPACE:	MOV	R2,R2
  D186   1204           	JLE	PADRETS
  D188   DD20 D015      PADLOOP:	MOVB	@SPACE,*R4+
  D18C   0602           	DEC	R2
  D18E   1BFC           	JH	PADLOOP
  D190   2DC0           PADRETS:	RET
                        
                        ;*******************************************************************
                        ;	CHKCHAR - check if char at *R3 is valid filename char
                        ;*******************************************************************
  D192   D053           CHKCHAR:	MOVB	*R3,R1
  D194   0981           	SRL	R1,8
  D196   0281 0030      	CI	R1,'0'
  D19A   1A0C           	JL	INVALID
  D19C   0281 0039      	CI	R1,'9'
  D1A0   1207           	JLE	VALID
  D1A2   0241 00DF      	ANDI	R1,00DFH
  D1A6   0221 FFBF      	AI	R1,-'A'
  D1AA   0281 001A      	CI	R1,001AH
  D1AE   1B02           	JH	INVALID
  D1B0   04C1           VALID:	CLR	R1
  D1B2   1002           	JMP	SETFLAG
  D1B4   0201 0001      INVALID:	LI	R1,1
  D1B8   C041           SETFLAG:	MOV	R1,R1
  D1BA   2DC0           	RET
                        
                        ;*******************************************************************
                        ;	SEG_SWITCH - deprecated v5.4 (transparent GAL mapping)
                        ;*******************************************************************
  D1BC   2DC0           SEG_SWITCH:	RET
                        
  D1BE   0460 D82A      SSWERR:	B	@PARSERR
                        
                        ;*******************************************************************
                        ;	PARSENAME - parse filename from command line into FCB
                        ;*******************************************************************
  D1C2   0204 0280      PARSENAME:	LI	R4,FCB
  D1C6   0202 0008      	LI	R2,NAMSIZ - EXTSIZ
  D1CA   04C0           	CLR	R0
                        
  D1CC   2DA0 D192      PARSE1:	CALL	@CHKCHAR
  D1D0   1604           	JNE	FILLNAME
  D1D2   DD33           	MOVB	*R3+,*R4+
  D1D4   0602           	DEC	R2
  D1D6   1303           	JEQ	FINDDOT
  D1D8   10F9           	JMP	PARSE1
                        
  D1DA   2DA0 D184      FILLNAME:	CALL	@PADSPACE
                        
  D1DE   9833 D01F      FINDDOT:	CB	*R3+,@EXT
  D1E2   130F           	JEQ	GETEXT
  D1E4   0603           	DEC	R3
  D1E6   0202 0003      	LI	R2,EXTSIZ
  D1EA   0204 0288      	LI	R4,FCB + NAMSIZ - EXTSIZ
  D1EE   2DA0 D184      	CALL	@PADSPACE
  D1F2   2DC0           	RET
                        
  D1F4   434F 4D        EXT_TAB:	TEXT	'COM'
  D1F7   4558 45        	TEXT	'EXE'
  D1FA   4241 53        	TEXT	'BAS'
  D1FD   4241 54        	TEXT	'BAT'
  D200   00             EXT_END:	BYTE	0
  D201   00             	EVEN
                        
  D202   0202 0003      GETEXT:	LI	R2,EXTSIZ
  D206   0204 0288      	LI	R4,FCB + NAMSIZ - EXTSIZ
  D20A   2DA0 D192      NEXTEXT:	CALL	@CHKCHAR
  D20E   1607           	JNE	FILLEXT
  D210   D073           	MOVB	*R3+,R1
  D212   0241 DF00      	ANDI	R1,0DF00H
  D216   DD01           	MOVB	R1,*R4+
  D218   0602           	DEC	R2
  D21A   1301           	JEQ	FILLEXT
  D21C   10F6           	JMP	NEXTEXT
  D21E   2DA0 D184      FILLEXT:	CALL	@PADSPACE
  D222   2DC0           	RET
                        
                        ;*******************************************************************
                        ;	SET_FTY - derive file type from FCB extension, store in MFTY
                        ;	FCB is absolute at 0280H - @FCB+EXTOFF etc are plain address constants
                        ;	Uses R5 (table base), R6 (entry walk), R7 (type counter), R0 (scratch)
                        ;
                        SET_FTY:
  D224   0205 D1F4      	LI	R5,EXT_TAB			; TABLE BASE
  D228   04C7           	CLR	R7				; TYPE CODE (0=SYS)
                        SFTY_LOOP:
  D22A   C185           	MOV	R5,R6				; R6 = ENTRY WALK POINTER
  D22C   D036           	MOVB	*R6+,R0				; BYTE 1
  D22E   130F           	JEQ	SFTY_NONE			; END OF TABLE
  D230   0587           	INC	R7				; NEXT TYPE CODE
  D232   9800 0288      	CB	R0,@FCB+EXTOFF			; COMPARE BYTE 1
  D236   1608           	JNE	SFTY_NEXT
  D238   D036           	MOVB	*R6+,R0				; BYTE 2
  D23A   9800 0289      	CB	R0,@FCB+EXTOFF+1		; COMPARE BYTE 2
  D23E   1604           	JNE	SFTY_NEXT
  D240   D016           	MOVB	*R6,R0				; BYTE 3
  D242   9800 028A      	CB	R0,@FCB+EXTOFF+2		; COMPARE BYTE 3
  D246   1304           	JEQ	SFTY_FOUND
                        SFTY_NEXT:
  D248   0225 0003      	AI	R5,3				; NEXT ENTRY
  D24C   10EE           	JMP	SFTY_LOOP
                        SFTY_NONE:
  D24E   04C7           	CLR	R7				; NO MATCH - SYS=0
                        SFTY_FOUND:
  D250   06C7           	SWPB	R7				; TYPE TO HIGH BYTE FOR MOVB
  D252   D807 DF1E      	MOVB	R7,@MFTY			; STORE TYPE CODE
  D256   2DC0           	RET
                        ;
                        ;	LOAD - load executable file
                        ;
                        ;	FLA in FCB gives load address (0 = use TPA).
                        ;	'.' prefix = flat load only, no execution, returns to prompt.
                        ;	COM/EXE/type 0 = LOADERCODE (handles paged and raw binaries).
                        ;*******************************************************************
  D258   04C1           LOAD:	CLR	R1
  D25A   D801 024E      	MOVB	R1,@CMDLINE-2
  D25E   0204 0280      	LI	R4,FCB
  D262   C0E4 0010      	MOV	@FLA(R4),R3
  D266   1602           	JNE	LOAD2
  D268   0203 0500      	LI	R3,TPA
  D26C   C803 DECA      LOAD2	MOV	R3,@LADDR
  D270   04E4 001A      	CLR	@CRN(R4)
                        
  D274   9820 0250      	CB	@CMDLINE,@JUMP
  D278   D01D           
  D27A   1617           	JNE	LOADRUN
  D27C   064A           LOADF3	DECT	SP
  D27E   C683           	MOV	R3,*SP
  D280   0202 001A      LOADF0	LI	R2,SETDMA
  D284   2DA0 E400      	CALL	@BDOS
  D288   0202 0014      	LI	R2,RDSEQ
  D28C   0203 0280      	LI	R3,FCB
  D290   2DA0 E400      	CALL	@BDOS
  D294   C0FA           	MOV	*SP+,R3
  D296   0281 FFFF      	CI	R1,-1
  D29A   1303           	JEQ	LOADF1
  D29C   0223 0200      	AI	R3,BLKSIZ
  D2A0   10ED           	JMP	LOADF3
  D2A2   C803 00A6      LOADF1	MOV	R3,@FREEMEM
  D2A6   0460 D666      	B	@NEXTCMD
                        
                        LOADRUN:
  D2AA   D064 000B      	MOVB	@FTY(R4),R1
  D2AE   0981           	SRL	R1,8
  D2B0   0281 0001      	CI	R1,COM
  D2B4   1602           	JNE	LT2
  D2B6   0460 D31A      	B	@GOPROG
  D2BA   0281 0002      LT2	CI	R1,EXE
  D2BE   1602           	JNE	LT3
  D2C0   0460 D34E      	B	@GOPROG_EXE		;EXE - PAGED CHAIN FORMAT
                        ;
                        ;IS THIS CODE REDUNDANT?  E TO DO TO DO
                        ;
                        LT3	;B	@NEXTCMD
                        
  D2C4   0281 0000      	CI	R1,0
  D2C8   1602           	JNE	LT4
  D2CA   0460 D31A      	B	@GOPROG
                        LT4
  D2CE   04E4 001A      	CLR	@CRN(R4)
  D2D2   064A           LOAD3	DECT	SP
  D2D4   C683           	MOV	R3,*SP
  D2D6   0202 001A      LOAD0	LI	R2,SETDMA
  D2DA   2DA0 E400      	CALL	@BDOS
  D2DE   0202 0014      	LI	R2,RDSEQ
  D2E2   0203 0280      	LI	R3,FCB
  D2E6   2DA0 E400      	CALL	@BDOS
  D2EA   C0FA           	MOV	*SP+,R3
  D2EC   0281 FFFF      	CI	R1,-1
  D2F0   1303           	JEQ	LOAD1
  D2F2   0223 0200      	AI	R3,BLKSIZ
  D2F6   10ED           	JMP	LOAD3
  D2F8   C803 00A6      LOAD1	MOV	R3,@FREEMEM
  D2FC   D060 DF1E      	MOVB	@MFTY,R1
  D300   0981           	SRL	R1,8
  D302   0281 0005      	CI	R1,PRO
  D306   1602           	JNE	LOAD1B
  D308   0460 D666      	B	@NEXTCMD
  D30C   0281 0003      LOAD1B	CI	R1,TXT
  D310   1602           	JNE	LOAD1C
  D312   0460 D666      	B	@NEXTCMD
  D316   0460 D666      LOAD1C	B	@NEXTCMD
                        
                        ;*******************************************************************
                        ;	GOPROG - run loaded program via LOADERCODE
                        ;*******************************************************************
  D31A   0204 0250      GOPROG	LI	R4,CMDLINE
  D31E   0584           GOLOOP	INC	R4
  D320   9814 D015      	CB	*R4,@SPACE
  D324   1BFC           	JH	GOLOOP
  D326   04C1           	CLR	R1
  D328   D801 024F      	MOVB	R1,@CMDLINE-1
  D32C   0200 0080      	LI	R0,SHELL_PTR
  D330   064A           	DECT	SP
  D332   C680           	MOV	R0,*SP
  D334   2DA0 D33C      	CALL	@INIT_LOADER
  D338   0460 0300      	B	@LOADER
                        
                        ;*******************************************************************
                        ;	INIT_LOADER - copy LOADERCODE to LOADER (0x0300)
                        ;*******************************************************************
  D33C   0202 0300      INIT_LOADER:	LI	R2,LOADER
  D340   0201 D53C      	LI	R1,LOADERCODE
  D344   CCB1           IL0:	MOV	*R1+,*R2+
  D346   0281 D60A      	CI	R1,END_LOADER
  D34A   1AFC           	JL	IL0
  D34C   2DC0           	RET
                        
                        ;*******************************************************************
                        ;	GOPROG_EXE - stub for paged EXE chain format (v5.7)
                        ;	Called when file type is EXE. Returns to caller.
                        ;	Full implementation pending BDOS EXE type verification.
                        ;*******************************************************************
                        ;*******************************************************************
                        ;	GOPROG_EXE - run EXE (paged chain format) via LOADERCODE_EXE
                        ;*******************************************************************
                        GOPROG_EXE:
  D34E   0204 0250      	LI	R4,CMDLINE
                        GOLOOP_E:
  D352   0584           	INC	R4
  D354   9814 D015      	CB	*R4,@SPACE
  D358   1BFC           	JH	GOLOOP_E
  D35A   04C1           	CLR	R1
  D35C   D801 024F      	MOVB	R1,@CMDLINE-1
  D360   0200 0080      	LI	R0,SHELL_PTR
  D364   064A           	DECT	SP
  D366   C680           	MOV	R0,*SP
  D368   2DA0 D370      	CALL	@INIT_LOADER_EXE
  D36C   0460 0300      	B	@LOADER
                        
                        ;*******************************************************************
                        ;	INIT_LOADER_EXE - copy LOADERCODE_EXE to LOADER (0x0300)
                        ;*******************************************************************
                        INIT_LOADER_EXE:
  D370   0202 0300      	LI	R2,LOADER
  D374   0201 D382      	LI	R1,LOADERCODE_EXE
  D378   CCB1           ILE0:	MOV	*R1+,*R2+
  D37A   0281 D4C8      	CI	R1,END_LOADER_EXE
  D37E   1AFC           	JL	ILE0
  D380   2DC0           	RET
                        
                        ;*******************************************************************
                        ;  LOADERCODE_EXE v5.7
                        ;
                        ;  Copied to LOADER (0x0300) by INIT_LOADER_EXE. Runs from COMMON.
                        ;
                        ;  Reads .EXE paged chain format produced by link99 v3.9.10.
                        ;
                        ;  Block header (8 bytes):
                        ;    +0  next_offset  word  byte distance from THIS header to next (0=last)
                        ;    +2  page         word  physical page (0=common/flat)
                        ;    +4  start        word  virtual load address
                        ;    +6  size         word  byte count of data following header
                        ;    +8  [data...]
                        ;
                        ;  Single forward pass:
                        ;    R6 -> header. Save R7=R6 (header start). Consume 4 words.
                        ;    Capture R8 from first block start only.
                        ;    MAP_SET if page != 0.
                        ;    PSEL on. Copy size bytes from R6 to start. PSEL off.
                        ;    If next_offset == 0 -> LDRRUN (launch).
                        ;    R6 = R7 + next_offset. Loop.
                        ;    Sector reload (LDRSEC_E) preserves R5/R7/R8 across BDOS.
                        ;    After reload R6 = STAGING + (old R6 - STAGING end).
                        ;
                        ;  Branches to LDRRUN/LDRRUN_LOAD/LDRERR in shell (always resident).
                        ;
                        ;  Key registers:
                        ;    R2   paged destination (start address, reset each block)
                        ;    R3   word count (saved across BDOS)
                        ;    R4   end of STAGING = EXE_STG_END
                        ;    R5   next_offset (saved across block copy and BDOS)
                        ;    R6   current STAGING pointer (header then data)
                        ;    R7   header start (for next_offset arithmetic)
                        ;    R8   launch address (first block start, never changed after)
                        ;    R9   scratch / PSEL value
                        ;*******************************************************************
                        
                        LOADERCODE_EXE:
                        
                        ;--- CLEAR ALL MAP REGISTERS TO PAGE 0 ---
  D382   020C 80C0      	LI	R12,MAP_WIN_BASE
  D386   04C0           	CLR	R0
  D388   0201 0010      	LI	R1,NUM_SEGS
                        LDRCL_E:
  D38C   3080           	LDCR	R0,BYTEWIDE
  D38E   05CC           	INCT	R12
  D390   0601           	DEC	R1
  D392   16FC           	JNE	LDRCL_E
                        
                        ;--- READ TWO SECTORS TO STAGING (EXE_STG to EXE_STG_END) ---
                        ; Two sectors avoids mid-block reload, keeping chain arithmetic valid.
  D394   04C0           	CLR	R0
  D396   0203 0500      	LI	R3,EXE_STG
  D39A   0202 001A      	LI	R2,SETDMA
  D39E   2DA0 E400      	CALL	@BDOS
  D3A2   0202 0014      	LI	R2,RDSEQ
  D3A6   0203 0280      	LI	R3,FCB
  D3AA   2DA0 E400      	CALL	@BDOS
  D3AE   0281 FFFF      	CI	R1,-1
  D3B2   1602           	JNE	LDREDET_E
  D3B4   0460 D60A      	B	@LDRRUN			;EMPTY FILE
                        LDREDET_E:
  D3B8   C041           	MOV	R1,R1
  D3BA   1101           	JLT	LDRERR_B
  D3BC   1002           	JMP	LDREDET_OK
                        LDRERR_B:
  D3BE   0460 D5E2      	B	@LDRERR
                        LDREDET_OK:
                        	;--- READ SECOND SECTOR TO EXE_STG2 ---
  D3C2   0203 0700      	LI	R3,EXE_STG2
  D3C6   0202 001A      	LI	R2,SETDMA
  D3CA   2DA0 E400      	CALL	@BDOS
  D3CE   0202 0014      	LI	R2,RDSEQ
  D3D2   0203 0280      	LI	R3,FCB
  D3D6   2DA0 E400      	CALL	@BDOS
                        	; IGNORE RESULT - FILE MAY FIT IN ONE SECTOR
                        
  D3DA   0206 0500      	LI	R6,EXE_STG		;R6 = FIRST BLOCK HEADER
  D3DE   0204 0900      	LI	R4,EXE_STG_END		;R4 = END OF STAGING
  D3E2   04C8           	CLR	R8			;R8=0 = LAUNCH ADDRESS NOT YET CAPTURED
  D3E4   04E0 02A6      	CLR	@OVL_COUNT		;RESET OVERLAY COUNTER BEFORE LOADING
                        
                        ;--- PROCESS ONE BLOCK HEADER ---
                        LDRBLK_E:
  D3E8   C1C6           	MOV	R6,R7			;R7 = HEADER START (FOR NEXT_OFFSET CALC)
  D3EA   C176           	MOV	*R6+,R5			;R5 = NEXT_OFFSET
  D3EC   C036           	MOV	*R6+,R0			;R0 = PAGE
  D3EE   C0B6           	MOV	*R6+,R2			;R2 = START (COPY DESTINATION)
  D3F0   C0F6           	MOV	*R6+,R3			;R3 = SIZE IN BYTES
                        				;R6 NOW AT FIRST DATA BYTE OF THIS BLOCK
                        
                        ;--- CAPTURE LAUNCH ADDRESS FROM FIRST BLOCK ONLY ---
  D3F2   C208           	MOV	R8,R8
  D3F4   1601           	JNE	LDRMAP_E
  D3F6   C202           	MOV	R2,R8			;R8 = LAUNCH ADDRESS (FIRST BLOCK START)
                        
                        ;--- PROGRAM MAPPER IF PAGED, REGISTER IN OVERLAY TABLES ---
                        LDRMAP_E:
  D3F8   C000           	MOV	R0,R0
  D3FA   130E           	JEQ	LDRCPY_E		; PAGE 0 = COMMON, NO MAP_SET OR TABLE ENTRY
                        
                        	;--- INCREMENT OVLID COUNTER AND REGISTER THIS BLOCK ---
                        	; OVL_COUNT starts at 0; each paged block gets next OVLID (1-based)
  D3FC   05A0 02A6      	INC	@OVL_COUNT		; OVLID = OVL_COUNT (1=first paged block)
  D400   C060 02A6      	MOV	@OVL_COUNT,R1		; R1 = OVLID
  D404   0601           	DEC	R1			; R1 = OVLID-1 (0-based word offset)
  D406   0A11           	SLA	R1,1			; R1 = (OVLID-1)*2
  D408   C840 02AC      	MOV	R0,@OVL_PAGE_TAB(R1)	; STORE PHYSICAL PAGE
  D40C   C242           	MOV	R2,R9
  D40E   09C9           	SRL	R9,12			; SEGMENT = START >> 12
  D410   C849 02CC      	MOV	R9,@OVL_SEG_TAB(R1)	; STORE VIRTUAL SEGMENT
                        
  D414   06A0 E054      	BL	@MAP_SET		; R9=SEGMENT R0=PAGE
                        
                        ;--- ENABLE PSEL AND COPY BLOCK ---
                        LDRCPY_E:
  D418   0209 0100      	LI	R9,PSEL_EN
  D41C   2C89           	PSEL	R9
  D41E   0913           	SRL	R3,1			;BYTES TO WORDS
                        					;R3 = WORD COUNT
                        LDRCPYW_E:
  D420   CCB6           	MOV	*R6+,*R2+		;COPY WORD STAGING -> PAGED
  D422   0603           	DEC	R3
  D424   132C           	JEQ	LDRDONE_E		;BLOCK DONE
  D426   8106           	C	R6,R4
  D428   1AFB           	JL	LDRCPYW_E		;MORE IN STAGING
                        
                        ;--- STAGING EXHAUSTED MID-BLOCK: RELOAD ---
                        LDRSEC_E:
  D42A   04C9           	CLR	R9
  D42C   2C89           	PSEL	R9			;PSEL OFF BEFORE BDOS
  D42E   064A           	DECT	SP
  D430   C688           	MOV	R8,*SP			;SAVE LAUNCH ADDRESS
  D432   064A           	DECT	SP
  D434   C687           	MOV	R7,*SP			;SAVE HEADER START
  D436   064A           	DECT	SP
  D438   C685           	MOV	R5,*SP			;SAVE NEXT_OFFSET
  D43A   064A           	DECT	SP
  D43C   C683           	MOV	R3,*SP			;SAVE WORD COUNT
  D43E   064A           	DECT	SP
  D440   C682           	MOV	R2,*SP			;SAVE PAGED DESTINATION
  D442   0203 0500      	LI	R3,EXE_STG
  D446   0202 001A      	LI	R2,SETDMA
  D44A   2DA0 E400      	CALL	@BDOS
  D44E   0202 0014      	LI	R2,RDSEQ
  D452   0203 0280      	LI	R3,FCB
  D456   2DA0 E400      	CALL	@BDOS
  D45A   C0BA           	MOV	*SP+,R2			;RESTORE PAGED DESTINATION
  D45C   C0FA           	MOV	*SP+,R3			;RESTORE WORD COUNT
  D45E   C17A           	MOV	*SP+,R5			;RESTORE NEXT_OFFSET
  D460   C1FA           	MOV	*SP+,R7			;RESTORE HEADER START
  D462   C23A           	MOV	*SP+,R8			;RESTORE LAUNCH ADDRESS
  D464   0281 FFFF      	CI	R1,-1
  D468   1602           	JNE	LDRSEC_EOK
  D46A   0460 D60A      	B	@LDRRUN			;EOF
                        LDRSEC_EOK:
  D46E   0209 0100      	LI	R9,PSEL_EN
  D472   2C89           	PSEL	R9
  D474   0206 0500      	LI	R6,EXE_STG		;RESET SOURCE
  D478   0204 0900      	LI	R4,EXE_STG_END		;RESET END OF STAGING
  D47C   10D1           	JMP	LDRCPYW_E
                        
                        ;--- BLOCK COPY COMPLETE ---
                        LDRDONE_E:
  D47E   04C9           	CLR	R9
  D480   2C89           	PSEL	R9			;PSEL OFF
                        
                        ;--- FOLLOW CHAIN ---
  D482   C145           	MOV	R5,R5
  D484   1602           	JNE	LDRCHAIN_E
  D486   0460 D60A      	B	@LDRRUN			;NEXT_OFFSET=0: LAST BLOCK, LAUNCH
                        LDRCHAIN_E:
                        
  D48A   A1C5           	A	R5,R7			;R7 = HEADER START + NEXT_OFFSET = NEXT HEADER
  D48C   C187           	MOV	R7,R6			;R6 = NEXT HEADER
                        
                        ;--- CHECK IF NEXT HEADER IN STAGING ---
  D48E   8106           	C	R6,R4
  D490   1AAB           	JL	LDRBLK_E		;IN STAGING - PROCESS IT
                        
                        ;--- NEXT HEADER BEYOND STAGING: RELOAD ---
                        ;  next header may land in the next sector. Calculate overshoot,
                        ;  reload, position R6 at overshoot offset within new sector.
  D492   6184           	S	R4,R6			;R6 = BYTES PAST END OF STAGING
  D494   064A           	DECT	SP
  D496   C688           	MOV	R8,*SP			;SAVE LAUNCH ADDRESS
  D498   064A           	DECT	SP
  D49A   C685           	MOV	R5,*SP			;SAVE NEXT_OFFSET (DONE WITH IT BUT TIDY)
  D49C   064A           	DECT	SP
  D49E   C686           	MOV	R6,*SP			;SAVE OVERSHOOT
  D4A0   0203 0500      	LI	R3,EXE_STG
  D4A4   0202 001A      	LI	R2,SETDMA
  D4A8   2DA0 E400      	CALL	@BDOS
  D4AC   0202 0014      	LI	R2,RDSEQ
  D4B0   0203 0280      	LI	R3,FCB
  D4B4   2DA0 E400      	CALL	@BDOS
  D4B8   C1BA           	MOV	*SP+,R6			;RESTORE OVERSHOOT
  D4BA   C17A           	MOV	*SP+,R5
  D4BC   C23A           	MOV	*SP+,R8			;RESTORE LAUNCH ADDRESS
  D4BE   0204 0900      	LI	R4,EXE_STG_END
  D4C2   0226 0500      	AI	R6,EXE_STG		;R6 = STAGING + OVERSHOOT
  D4C6   1090           	JMP	LDRBLK_E
                        
  D4C8                  END_LOADER_EXE:	EQU	$+0
                        
                        ;*******************************************************************
                        ;  COPY_OVLMGR - copy OVLMGR code to common at OVLMGR_BASE (0A00H)
                        ;
                        ;  Called once at shell startup (INIT). Copies OVLMGR_CODE to 0A00H
                        ;  then installs vectors at OVL_INIT_VEC/OVL_SWAP_VEC.
                        ;  Uses BL/RT (R11 = return address).
                        ;  Modifies: R0, R1, R2
                        ;*******************************************************************
                        COPY_OVLMGR:
  D4C8   0200 D4EE      	LI	R0,OVLMGR_CODE			; SOURCE IN SHELL
  D4CC   0201 0A00      	LI	R1,OVLMGR_BASE			; DESTINATION = 0A00H
  D4D0   0202 004E      	LI	R2,OVLMGR_CODE_END-OVLMGR_CODE	; SIZE IN BYTES
  D4D4   0912           	SRL	R2,1				; TO WORDS
                        COPY_OVL1:
  D4D6   CC70           	MOV	*R0+,*R1+
  D4D8   0602           	DEC	R2
  D4DA   16FD           	JNE	COPY_OVL1
                        	;--- INSTALL VECTOR ADDRESSES ---
                        	; Callers use: MOV @OVL_INIT_VEC,R0 / BL *R0
  D4DC   0200 D4F6      	LI	R0,OVLMGR_CI			; ADDRESS OF OVLMGR_INIT CODE
  D4E0   C800 02A2      	MOV	R0,@OVL_INIT_VEC		; 02A2H
  D4E4   0200 D508      	LI	R0,OVLMGR_C			; ADDRESS OF OVLMGR CODE
  D4E8   C800 02A4      	MOV	R0,@OVL_SWAP_VEC		; 02A4H
  D4EC   045B           	RT
                        
                        ;*******************************************************************
                        ;  OVLMGR_CODE - overlay manager code stored in shell, copied to 0A00H
                        ;
                        ;  This is position-independent code - all addresses are absolute.
                        ;  When copied to 0A00H the layout is:
                        ;    0A00H  B @OVLMGR_INIT  (4 bytes)
                        ;    0A04H  B @OVLMGR       (4 bytes)
                        ;    0A08H  OVLMGR_INIT code
                        ;    0A??H  OVLMGR code
                        ;
                        ;  NOTE: assembled inline here but logically runs at 0A00H.
                        ;  All absolute addresses (OVL_PAGE_TAB, MAP_WIN_BASE etc) are
                        ;  correct regardless of where this code is stored in the shell.
                        ;*******************************************************************
                        OVLMGR_CODE:
                        	;--- VECTOR TABLE ---
  D4EE   0460 D4F6      	B	@OVLMGR_CI			; 0A00H: -> OVLMGR_INIT
  D4F2   0460 D508      	B	@OVLMGR_C			; 0A04H: -> OVLMGR
                        
                        	;--- OVLMGR_INIT ---
                        	; Clear current overlay state, enable PSEL
                        	; Entry: nothing  Exit: OVL_CURR_ID=0, PSEL enabled
                        	; R11 = return address (BL caller)
                        OVLMGR_CI:
  D4F6   04C0           	CLR	R0
  D4F8   C800 02A8      	MOV	R0,@OVL_CURR_ID			; NO OVERLAY LOADED
  D4FC   C800 02AA      	MOV	R0,@OVL_CURR_SEG			; NO SEGMENT MAPPED
  D500   0209 0100      	LI	R9,PSEL_EN
  D504   2C89           	PSEL	R9				; ENABLE PSEL
  D506   045B           	B	*R11				; RETURN (BL caller)
                        
                        	;--- OVLMGR ---
                        	; Entry:  R1 = OVLID (1-based)
                        	; Exit:   segment mapped to physical page, PSEL enabled
                        	; Modifies: R0, R3, R9, R12
                        	; Preserves: R1, R2, R4-R8, R10, R11, R13-R15
                        OVLMGR_C:
                        	;--- ALREADY LOADED? ---
  D508   8801 02A8      	C	R1,@OVL_CURR_ID
  D50C   1316           	JEQ	OVLMGR_CR			; YES - NOTHING TO DO
                        
                        	;--- UPDATE CURRENT STATE ---
  D50E   C801 02A8      	MOV	R1,@OVL_CURR_ID
                        
                        	;--- LOOK UP PAGE AND SEGMENT FOR THIS OVLID ---
                        	; Tables at OVL_PAGE_TAB/OVL_SEG_TAB, word-indexed by (OVLID-1)
  D512   C0C1           	MOV	R1,R3
  D514   0603           	DEC	R3				; R3 = OVLID-1 (0-based)
  D516   0A13           	SLA	R3,1				; R3 = (OVLID-1)*2 (word offset)
                        						; NOTE: R0 cannot be used as index on TMS9900
  D518   C023 02AC      	MOV	@OVL_PAGE_TAB(R3),R0		; R0 = PHYSICAL PAGE
  D51C   C263 02CC      	MOV	@OVL_SEG_TAB(R3),R9		; R9 = VIRTUAL SEGMENT
  D520   C809 02AA      	MOV	R9,@OVL_CURR_SEG
                        
                        	;--- DISABLE PSEL BEFORE CRU ACCESS ---
  D524   04CC           	CLR	R12
  D526   2C8C           	PSEL	R12
                        
                        	;--- PROGRAM MAPPER: SEGMENT R9 -> PAGE R0 ---
  D528   020C 80C0      	LI	R12,MAP_WIN_BASE
  D52C   0A19           	SLA	R9,1				; SEGMENT*2 = CRU BIT OFFSET
  D52E   A309           	A	R9,R12				; R12 = CRU ADDRESS FOR THIS SEGMENT
  D530   0A80           	SLA	R0,8				; PAGE TO HIGH BYTE FOR LDCR
  D532   3080           	LDCR	R0,BYTEWIDE
                        
                        	;--- RE-ENABLE PSEL ---
  D534   0209 0100      	LI	R9,PSEL_EN
  D538   2C89           	PSEL	R9
                        
                        OVLMGR_CR:
  D53A   045B           	B	*R11				; RETURN (BL caller)
                        
  D53C                  OVLMGR_CODE_END:	EQU	$+0
                        
                        ;*******************************************************************
                        ;  LOADERCODE v5.7
                        ;
                        ;  Copied to LOADER (0x0300) by INIT_LOADER. Runs from COMMON.
                        ;  Handles .COM flat binary files only.
                        ;  .EXE paged chain format is handled by LOADERCODE_EXE.
                        ;
                        ;  Load sequence:
                        ;    1. Read first sector to STAGING
                        ;    2. Copy STAGING to LADDR, read remaining sectors to LADDR+N
                        ;    3. Launch from LADDR (no PSEL, mapper untouched)
                        ;
                        ;  Key registers:
                        ;    R3   sector DMA address / load pointer
                        ;    R9   launch address (= LADDR)
                        ;*******************************************************************
                        
                        LOADERCODE:
                        
                        ;--- ENSURE PSEL DISABLED BEFORE ANY BDOS CALLS ---
  D53C   04CF           	CLR	R15
  D53E   026F 0007      	ORI	R15,0007H		;INTERRUPT MASK=7, PSEL BIT CLEAR
  D542   008F           	LST	R15
                        
                        ;--- READ FIRST SECTOR TO STAGING (0x0500) ---
  D544   04C0           	CLR	R0
  D546   0203 0500      	LI	R3,0500H		;STAGING BUFFER
  D54A   0202 001A      	LI	R2,SETDMA
  D54E   2DA0 E400      	CALL	@BDOS
  D552   0202 0014      	LI	R2,RDSEQ
  D556   0203 0280      	LI	R3,FCB
  D55A   2DA0 E400      	CALL	@BDOS
  D55E   0281 FFFF      	CI	R1,-1
  D562   1602           	JNE	LDRDET
  D564   0460 D5C0      	B	@LDRRUN_F		;EMPTY FILE
  D568   C041           LDRDET:	MOV	R1,R1
  D56A   1101           	JLT	LDRDET_ERR
  D56C   1002           	JMP	LDRRAW
                        LDRDET_ERR:
  D56E   0460 D5E2      	B	@LDRERR
                        
                        ;--- RAW BINARY: LOAD TO LADDR, LAUNCH FROM LADDR ---
  D572   C260 DECA      LDRRAW:	MOV	@LADDR,R9		;R9 = LAUNCH ADDRESS
  D576   0203 0500      	LI	R3,0500H		;COPY STAGING -> LADDR
  D57A   C120 DECA      	MOV	@LADDR,R4
  D57E   CD33           LDRRAW1:MOV	*R3+,*R4+
  D580   0283 0700      	CI	R3,0700H		;END OF STAGING
  D584   1AFC           	JL	LDRRAW1
  D586   C0E0 DECA      	MOV	@LADDR,R3
  D58A   0223 0200      	AI	R3,BYTSEC		;NEXT SECTOR
                        
  D58E   064A           LDRRAWS:DECT	SP
  D590   C683           	MOV	R3,*SP
  D592   0202 001A      	LI	R2,SETDMA
  D596   2DA0 E400      	CALL	@BDOS
  D59A   0202 0014      	LI	R2,RDSEQ
  D59E   0203 0280      	LI	R3,FCB
  D5A2   2DA0 E400      	CALL	@BDOS
  D5A6   C0FA           	MOV	*SP+,R3
  D5A8   0281 FFFF      	CI	R1,-1
  D5AC   1602           	JNE	LDRRAWS1
  D5AE   0460 D5C0      	B	@LDRRUN_F
                        LDRRAWS1:
  D5B2   C041           	MOV	R1,R1
  D5B4   1103           	JLT	LDRRAWS_ERR
  D5B6   0223 0200      	AI	R3,BYTSEC
  D5BA   10E9           	JMP	LDRRAWS
                        LDRRAWS_ERR:
  D5BC   0460 D5E2      	B	@LDRERR
                        
                        ;--- LAUNCH RAW/FLAT (NO PSEL) ---
                        LDRRUN_F:
  D5C0   C020 D734      	MOV	@LOAD_ONLY,R0		;LOAD ONLY?
  D5C4   1302           	JEQ	LDRRUN_F1		;NO - EXECUTE
  D5C6   0460 D628      	B	@LDRRUN_LOAD		;YES - ABSOLUTE BRANCH TO SHELL
                        LDRRUN_F1:
  D5CA   0200 DFD8      	LI	R0,INT2_HANDLER		;INSTALL INT2 DEBUG HANDLER
  D5CE   C800 000A      	MOV	R0,@INT2_VEC
  D5D2   04C0           	CLR	R0			;DISABLE PSEL WITHOUT CLOBBERING R9
  D5D4   2C80           	PSEL	R0			;ENSURE PSEL DISABLED FOR FLAT COM LAUNCH
  D5D6   04CF           	CLR	R15			;CLEAR ALL STATUS BITS
  D5D8   026F 0007      	ORI	R15,0007H		;ST7=0=PRIVILEGED, INTERRUPT MASK=7
  D5DC   008F           	LST	R15
  D5DE   C089           	MOV	R9,R2
  D5E0   0452           	B	*R2
                        
  D5E2   2FA0 D5EA      LDRERR:	MESG	@TXT_LDRERR
  D5E6   0460 D63A      	B	@RETURN
                        
  D5EA   2D2D 4C6F      TXT_LDRERR:	TEXT	'--Loader read error'
  D5EE   6164 6572      
  D5F2   2072 6561      
  D5F6   6420 6572      
  D5FA   726F 72        
  D5FD   0D0A 00        		BYTE	0DH,0AH,0
  D600                  		EVEN
  D600   4C6F 6164      TXT_LOADED:	TEXT	'Loaded'
  D604   6564           
  D606   0D0A 00        		BYTE	0DH,0AH,0
  D609   00             		EVEN
                        
  D60A                  END_LOADER:	EQU	$+0
                        
                        ;*******************************************************************
                        ;  LDRRUN / LDRRUN_LOAD - permanent shell routines
                        ;  Called by both LOADERCODE (COM) and LOADERCODE_EXE (EXE).
                        ;  Must live in protected shell segments, never inside a LOADERCODE
                        ;  block. Absolute B @LDRRUN branches from COMMON are safe because
                        ;  shell is always resident in segments 12-15.
                        ;*******************************************************************
                        
                        ;--- LAUNCH PAGED PROGRAM (PSEL WILL BE ENABLED) ---
  D60A   C020 D734      LDRRUN:	MOV	@LOAD_ONLY,R0		;LOAD ONLY?
  D60E   160C           	JNE	LDRRUN_LOAD		;YES - SKIP EXECUTE
  D610   0200 DFD8      	LI	R0,INT2_HANDLER
  D614   C800 000A      	MOV	R0,@INT2_VEC
  D618   04CF           	CLR	R15
  D61A   026F 0007      	ORI	R15,0007H		;ST7=0=PRIVILEGED, INTERRUPT MASK=7
  D61E   008F           	LST	R15
  D620   0209 0100      	LI	R9,PSEL_EN		;ENABLE PSEL BEFORE LAUNCH
  D624   2C89           	PSEL	R9
                        ;	HALT
  D626   0458           	B	*R8			;LAUNCH FROM R8
                        
                        LDRRUN_LOAD:
  D628   04C9           	CLR	R9
  D62A   2C89           	PSEL	R9			;DISABLE PSEL
  D62C   04C0           	CLR	R0
  D62E   C800 D734      	MOV	R0,@LOAD_ONLY		;CLEAR FLAG
  D632   2FA0 D600      	MESG	@TXT_LOADED		;CONFIRM LOAD
  D636   0460 D666      	B	@NEXTCMD		;BACK TO SHELL PROMPT
                        ;*******************************************************************
                        ;	RETURN - program exit
                        ;*******************************************************************
  D63A   06A0 E03C      RETURN:	BL	@MAP_INIT
  D63E   D801 024E      	MOVB	R1,@CMDLINE-2
  D642   02E0 0230      	LWPI	WORKSP
  D646   020A 1000      	LI	SP,STACKP
  D64A   04CF           	CLR	R15
  D64C   D060 024E      	MOVB	@CMDLINE-2,R1
  D650   0881           	SRA	R1,8
  D652   0281 FFFF      	CI	R1,-1
  D656   1607           	JNE	NEXTCMD
  D658   04C1           	CLR	R1
  D65A   D801 024E      	MOVB	R1,@CMDLINE-2
  D65E   C041           	MOV	R1,R1
  D660   1302           	JEQ	NEXTCMD
  D662   0460 DD84      	B	@UNPROC
                        
                        ;*******************************************************************
                        ;	NEXTCMD / PROMPT
                        ;*******************************************************************
  D666   D060 DEC0      NEXTCMD	MOVB	@PROCSW,R1
  D66A   1302           	JEQ	PROMPT
  D66C   0460 DBCC      	B	@PFETCH
                        
  D670   D0E0 D021      PROMPT:	MOVB	@PROM,R3
  D674   2DA0 DE7E      	CALL	@OUTCHAR
  D678   0204 0250      	LI	R4,CMDLINE
  D67C   0205 0040      	LI	R5,CLSZ
  D680   C060 0000      CINLOOP	MOV	@CONSOLE,R1
  D684   2DA0 DE72      	CALL	@INCHAR
  D688   9801 D017      	CB	R1,@BS
  D68C   132A           	JEQ	RUBOUT
  D68E   9801 D01A      	CB	R1,@DEL
  D692   1327           	JEQ	RUBOUT
  D694   9801 D010      	CB	R1,@CTLC
  D698   1604           	JNE	STOWIT
  D69A   D060 D018      	MOVB	@CR,R1
  D69E   D801 0250      	MOVB	R1,@CMDLINE
                        
  D6A2   C001           STOWIT	MOV	R1,R0
  D6A4   0980           	SRL	R0,8
  D6A6   0280 0061      	CI	R0,61H
  D6AA   1A08           	JL	STOWIT2
  D6AC   0280 007A      	CI	R0,7AH
  D6B0   1B05           	JH	STOWIT2
  D6B2   0220 FFE0      	AI	R0,-20H
  D6B6   06C0           	SWPB	R0
  D6B8   DD00           	MOVB	R0,*R4+
  D6BA   1001           	JMP	STOWIT2+2
  D6BC   DD01           STOWIT2	MOVB	R1,*R4+
  D6BE   0605           	DEC	R5
  D6C0   1224           	JLE	CIOERR
  D6C2   9801 D015      	CB	R1,@SPACE
  D6C6   1404           	JHE	ECHO
  D6C8   04C0           	CLR	R0
  D6CA   D060 D018      	MOVB	@CR,R1
  D6CE   D500           	MOVB	R0,*R4
  D6D0   C0C1           ECHO	MOV	R1,R3
  D6D2   2DA0 DE7E      	CALL	@OUTCHAR
  D6D6   04E0 DEC2      	CLR	@SKIPSW
  D6DA   9801 D019      	CB	R1,@LF
  D6DE   130E           	JEQ	GODOCMD
  D6E0   10CF           	JMP	CINLOOP
  D6E2   0285 0040      RUBOUT	CI	R5,CLSZ
  D6E6   14CC           	JHE	CINLOOP
  D6E8   0585           	INC	R5
  D6EA   0604           	DEC	R4
  D6EC   064A           	DECT	SP
  D6EE   C684           	MOV	R4,*SP
  D6F0   0204 DF8C      	LI	R4,RUBMSG
  D6F4   2DA0 DEA8      	CALL	@OUTSTR
  D6F8   C13A           	MOV	*SP+,R4
  D6FA   10C2           	JMP	CINLOOP
  D6FC   0200 0250      GODOCMD	LI	R0,CMDLINE
  D700   6100           	S	R0,R4
  D702   C804 00A2      	MOV	R4,@CMDL_SIZE
  D706   0460 D0CA      	B	@DOCMD
  D70A   0460 DD52      CIOERR	B	@LINERR
                        
                        ;*******************************************************************
                        ;	INTERNAL COMMANDS
                        ;*******************************************************************
  0005                  CMDCNT	EQU	5
  D70E   4449 52        ICLIST	TEXT	"DIR"
  D711   00             	BYTE	0
  D712   D78C           	WORD	DSKDIR
  D714   5341 5645      	TEXT	"SAVE"
  D718   00             	BYTE	0
  D719   D82E           	WORD	DSKSAVE
  D71B   4552 41        	TEXT	"ERA"
  D71E   00             	BYTE	0
  D71F   D92E           	WORD	ERAFILE
  D721   5459 5045      	TEXT	"TYPE"
  D725   00             	BYTE	0
  D726   DB0C           	WORD	TYPEFILE
  D728   4C4F 4144      	TEXT	"LOAD"
  D72C   00             	BYTE	0
  D72D   D9BA           	WORD	DOLOAD
  D72F   00             	EVEN
                        
  D730   0000           BUFPNT	WORD	0
  D732   0000           RECCNT	WORD	0
  D734   0000           LOAD_ONLY:	WORD	0			;NON-ZERO = LOAD WITHOUT EXECUTE
  D736   0000           SADDR	WORD	0
  D738   2D             SWITCH	BYTE	'-'
  D739   00             	EVEN
                        
  D73A   0201 D70E      ICMD	LI	R1,ICLIST
  D73E   0204 0280      	LI	R4,FCB
  D742   0205 0005      	LI	R5,CMDCNT
  D746   9C74           ICMD0	CB	*R4+,*R1+
  D748   13FE           	JEQ	ICMD0
  D74A   0601           	DEC	R1
  D74C   0604           	DEC	R4
  D74E   9814 D015      	CB	*R4,@SPACE
  D752   1B09           	JH	ICMD1
  D754   D011           	MOVB	*R1,R0
  D756   1607           	JNE	ICMD1
  D758   0581           	INC	R1
  D75A   D0B1           	MOVB	*R1+,R2
  D75C   06C2           	SWPB	R2
  D75E   D0B1           	MOVB	*R1+,R2
  D760   06C2           	SWPB	R2
  D762   C03A           	MOV	*SP+,R0
  D764   0452           	B	*R2
  D766   0605           ICMD1	DEC	R5
  D768   1306           	JEQ	ICMDE
  D76A   D031           ICMD2	MOVB	*R1+,R0
  D76C   16FE           	JNE	ICMD2
  D76E   05C1           	INCT	R1
  D770   0204 0280      	LI	R4,FCB
  D774   10E8           	JMP	ICMD0
  D776   2DC0           ICMDE	RET
                        
                        ;*******************************************************************
                        ;	DIR
                        ;*******************************************************************
  D778   203A 20        BAR	TEXT	' : '
  D77B   00             	BYTE	0
  D77C   0D0A 00        CRLF	BYTE	0DH,0AH,0
  D77F   4E4F 2046      MNOFILE	TEXT	'NO FILES'
  D783   494C 4553      
  D787   0D0A 00        	BYTE	0DH,0AH,0
  D78A                  	EVEN
  D78A   0000           CCOUNT	WORD	0
  D78C                  	EVEN
                        
  D78C   0200 0001      DSKDIR:	LI	R0,1
  D790   C800 D78A      	MOV	R0,@CCOUNT
  D794   0201 3F00      	LI	R1,'?'*256
  D798   0200 000B      	LI	R0,NAMSIZ
  D79C   0208 0280      	LI	R8,FCB
  D7A0   C088           	MOV	R8,R2
  D7A2   DC81           DSKDIR0	MOVB	R1,*R2+
  D7A4   0600           	DEC	R0
  D7A6   16FD           	JNE	DSKDIR0
  D7A8   0202 0011      	LI	R2,SEARCH1
  D7AC   0203 0280      	LI	R3,FCB
  D7B0   2DA0 E400      	CALL	@BDOS
  D7B4   C041           	MOV	R1,R1
  D7B6   1134           	JLT	NOFILE
  D7B8   2DA0 D7D2      	CALL	@PNAME
  D7BC   0202 0012      DSKDIR1	LI	R2,SEARCH2
  D7C0   0203 0280      	LI	R3,FCB
  D7C4   2DA0 E400      	CALL	@BDOS
  D7C8   C041           	MOV	R1,R1
  D7CA   1125           	JLT	DIREXIT
  D7CC   2DA0 D7D2      	CALL	@PNAME
  D7D0   10F5           	JMP	DSKDIR1
                        
  D7D2   0620 D78A      PNAME	DEC	@CCOUNT
  D7D6   1606           	JNE	PNAME1
  D7D8   2FA0 D77C      	MESG	@CRLF
  D7DC   0201 0001      	LI	R1,1
  D7E0   C801 D78A      	MOV	R1,@CCOUNT
  D7E4   C043           PNAME1	MOV	R3,R1
  D7E6   0200 000B      	LI	R0,NAMSIZ
  D7EA   064A           PNAME2	DECT	SP
  D7EC   C680           	MOV	R0,*SP
  D7EE   D0F1           	MOVB	*R1+,R3
  D7F0   06C3           	SWPB	R3
  D7F2   064A           	DECT	SP
  D7F4   C681           	MOV	R1,*SP
  D7F6   0202 0002      	LI	R2,COUT
  D7FA   2DA0 E400      	CALL	@BDOS
  D7FE   C07A           	MOV	*SP+,R1
  D800   C03A           	MOV	*SP+,R0
  D802   0600           	DEC	R0
  D804   16F2           	JNE	PNAME2
  D806   C020 D78A      	MOV	@CCOUNT,R0
  D80A   0280 0001      	CI	R0,1
  D80E   1302           	JEQ	PNAME3
  D810   2FA0 D77C      	MESG	@CRLF
  D814   2DC0           PNAME3	RET
                        
  D816   2FA0 D77C      DIREXIT	MESG	@CRLF
  D81A   04C1           	CLR	R1
  D81C   0460 D63A      	B	@RETURN
  D820   2FA0 D77F      NOFILE	MESG	@MNOFILE
  D824   04C1           	CLR	R1
  D826   0460 DD4C      	B	@CMDERR
                        
                        ;*******************************************************************
                        ;	SAVE
                        ;*******************************************************************
  00A0                  CMDPTR	EQU	0A0H
  D82A   0460 D99C      PARSERR	B	@PARSMSG
                        
  D82E   04E0 D730      DSKSAVE:	CLR	@BUFPNT
  D832   04E0 D732      	CLR	@RECCNT
  D836   0203 0500      	LI	R3,TPA
  D83A   C803 D736      	MOV	R3,@SADDR
  D83E   0203 0250      	LI	R3,CMDLINE
  D842   9833 D015      START00	CB	*R3+,@SPACE
  D846   1BFD           	JH	START00
  D848   0603           	DEC	R3
  D84A   9813 D018      START02	CB	*R3,@CR
  D84E   13ED           	JEQ	PARSERR
  D850   9833 D015      	CB	*R3+,@SPACE
  D854   12FA           	JLE	START02
  D856   0603           	DEC	R3
  D858   C803 D730      	MOV	R3,@BUFPNT
  D85C   2DA0 DB10      	CALL	@ATOD
  D860   C041           	MOV	R1,R1
  D862   13E3           	JEQ	PARSERR
  D864   C801 D732      	MOV	R1,@RECCNT
  D868   C0E0 D730      	MOV	@BUFPNT,R3
  D86C   9813 D018      PREPARSE	CB	*R3,@CR
  D870   13DC           	JEQ	PARSERR
  D872   9833 D015      	CB	*R3+,@SPACE
  D876   12FA           	JLE	PREPARSE
  D878   0603           	DEC	R3
  D87A   2DA0 D1C2      	CALL	@PARSENAME
  D87E   9833 D015      NAM2	CB	*R3+,@SPACE
  D882   13FD           	JEQ	NAM2
  D884   0603           	DEC	R3
  D886   9813 D018      	CB	*R3,@CR
  D88A   130B           	JEQ	NAMSRCH
  D88C   9833 D738      	CB	*R3+,@SWITCH
  D890   16CC           	JNE	PARSERR
  D892   C803 D730      	MOV	R3,@BUFPNT
  D896   2DA0 DB3C      	CALL	@CATOH
  D89A   C041           	MOV	R1,R1
  D89C   13C6           	JEQ	PARSERR
  D89E   C801 D736      	MOV	R1,@SADDR
  D8A2   0202 0011      NAMSRCH	LI	R2,SEARCH1
  D8A6   0203 0280      	LI	R3,FCB
  D8AA   2DA0 E400      	CALL	@BDOS
  D8AE   C041           	MOV	R1,R1
  D8B0   1106           	JLT	NAM5
  D8B2   0202 0013      NAM3	LI	R2,ERAFIL
  D8B6   0203 0280      	LI	R3,FCB
  D8BA   2DA0 E400      	CALL	@BDOS
  D8BE   0202 0016      NAM5	LI	R2,MAKFIL
  D8C2   0203 0280      	LI	R3,FCB
  D8C6   2DA0 E400      	CALL	@BDOS
  D8CA   C041           	MOV	R1,R1
  D8CC   1402           	JHE	SKMK1
  D8CE   0460 D98C      	B	@MKERR
                        SKMK1:
  D8D2   0204 0280      	LI	R4,FCB
  D8D6   C0E0 D736      	MOV	@SADDR,R3
  D8DA   C903 0010      	MOV	R3,@FLA(R4)
  D8DE   04E4 001A      	CLR	@CRN(R4)
  D8E2   064A           WRDATA	DECT	SP
  D8E4   C683           	MOV	R3,*SP
  D8E6   0202 001A      	LI	R2,SETDMA
  D8EA   2DA0 E400      	CALL	@BDOS
  D8EE   0202 0015      	LI	R2,WRSEQ
  D8F2   0203 0280      	LI	R3,FCB
  D8F6   2DA0 E400      	CALL	@BDOS
  D8FA   C0FA           	MOV	*SP+,R3
  D8FC   C041           	MOV	R1,R1
  D8FE   1402           	JHE	SKWR1
  D900   0460 D986      	B	@WRITERR
                        SKWR1:
  D904   8803 00B0      	C	R3,@MEMLIMIT
  D908   1A02           	JL	SKLG1
  D90A   0460 D9A4      	B	@LARGERR
                        SKLG1:
  D90E   0223 0200      	AI	R3,BYTSEC
  D912   0620 D732      	DEC	@RECCNT
  D916   16E5           	JNE	WRDATA
  D918   0202 0010      WRDATAC	LI	R2,FCLOSE
  D91C   0203 0280      	LI	R3,FCB
  D920   2DA0 E400      	CALL	@BDOS
  D924   04C1           EXIT	CLR	R1
  D926   0460 D63A      	B	@RETURN
                        
                        ;*******************************************************************
                        ;	ERASE
                        ;*******************************************************************
  D92A   0460 D99C      ERAPERR	B	@PARSMSG
                        
  D92E   04E0 D732      ERAFILE	CLR	@RECCNT
  D932   04E0 D730      	CLR	@BUFPNT
  D936   0203 0500      	LI	R3,TPA
  D93A   C803 D736      	MOV	R3,@SADDR
  D93E   0203 0250      	LI	R3,CMDLINE
  D942   9833 D015      ERA0	CB	*R3+,@SPACE
