                        ;*******************************************************************
  DBCC   0204 0040      PFETCH	LI	R4,CLSZ
  DBD0   C804 DEB8      	MOV	R4,@CMDBYTES
  DBD4   0204 0250      	LI	R4,CMDLINE
  DBD8   C804 DEB6      	MOV	R4,@CMDADDR
  DBDC   04E0 DEC8      	CLR	@SUBFLAG
  DBE0   C120 DF2A      PLOOP	MOV	@MCNT,R4
  DBE4   1626           	JNE	BUFMOVE
  DBE6   C120 DF20      	MOV	@MFSZ,R4
  DBEA   1321           	JEQ	PROCERR1
  DBEC   0203 0000      	LI	R3,DEFDRV
  DBF0   0202 000E      	LI	R2,SELDSK
  DBF4   2DA0 E400      	CALL	@BDOS
  DBF8   0203 0300      	LI	R3,COMM_BUF
  DBFC   0202 001A      	LI	R2,SETDMA
  DC00   2DA0 E400      	CALL	@BDOS
  DC04   0203 0280      	LI	R3,FCB
  DC08   0202 0014      	LI	R2,RDSEQ
  DC0C   2DA0 E400      	CALL	@BDOS
  DC10   C041           	MOV	R1,R1
  DC12   110B           	JLT	PROCERR0
  DC14   0201 0200      	LI	R1,BLKSIZ
  DC18   C801 DF2A      	MOV	R1,@MCNT
  DC1C   0204 0300      	LI	R4,COMM_BUF
  DC20   C804 DF2C      	MOV	R4,@MADDR
  DC24   0620 DF20      	DEC	@MFSZ
  DC28   1004           	JMP	BUFMOVE
  DC2A   0460 DD62      PROCERR0	B	@SHELLERR
  DC2E   0460 DD84      PROCERR1	B	@UNPROC
                        
  DC32   C120 DF2C      BUFMOVE	MOV	@MADDR,R4
  DC36   D074           	MOVB	*R4+,R1
  DC38   C804 DF2C      	MOV	R4,@MADDR
  DC3C   0620 DF2A      	DEC	@MCNT
  DC40   064A           	DECT	SP
  DC42   C681           	MOV	R1,*SP
  DC44   C020 DEC8      	MOV	@SUBFLAG,R0
  DC48   1621           	JNE	PARMSUB
  DC4A   C07A           	MOV	*SP+,R1
  DC4C   9801 D022      	CB	R1,@SUBMARK
  DC50   1603           	JNE	BUFMOV2
  DC52   0720 DEC8      	SETO	@SUBFLAG
  DC56   10C4           	JMP	PLOOP
  DC58   9801 D01B      BUFMOV2	CB	R1,@EOF
  DC5C   1313           	JEQ	BUFMOV4
