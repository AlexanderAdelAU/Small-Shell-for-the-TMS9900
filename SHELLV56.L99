                        ;	INT2_HANDLER - Paged execution crash debug
                        ;
                        ;	Fires when an exception occurs in paged code.
                        ;	Prints PC, WP, ST at point of exception, then dumps
                        ;	all 16 map registers, then returns to monitor.
                        ;*******************************************************************
                        INT2_HANDLER:
  DE1E   2FA0 DE62      	MESG	@TXT_INT2PC
  DE22   2E8E           	WHEX	R14			;PC AT EXCEPTION
  DE24   2FA0 DE6C      	MESG	@TXT_INT2WP
  DE28   2E8D           	WHEX	R13			;WORKSPACE POINTER
  DE2A   2FA0 DE72      	MESG	@TXT_INT2ST
  DE2E   2E8F           	WHEX	R15			;STATUS REGISTER
  DE30   2FA0 DE7E      	MESG	@TXT_INT2NL
  DE34   04C9           	CLR	R9
  DE36   2C89           	PSEL	R9			;DISABLE PSEL BEFORE READING MAP REGISTERS
  DE38   2FA0 DE78      	MESG	@TXT_INT2MAP
  DE3C   020C 80C0      	LI	R12,MAP_WIN_BASE
  DE40   04C8           	CLR	R8
